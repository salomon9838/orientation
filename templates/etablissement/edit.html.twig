{% extends 'base.html.twig' %}

{% block title %}Éditer l'établissement - SchoolPrepar{% endblock %}

{% block body %}
<div class="container py-5">
    <div class="row mb-4">
        <div class="col-12">
            <h1 class="display-6 fw-bold text-primary">
                <i class="fa fa-edit"></i> Éditer l'établissement
            </h1>
            <p class="text-muted">{{ etablissement.nom }}</p>
        </div>
    </div>

    <div class="row">
        <div class="col-lg-8">
            {% include 'etablissement/_form.html.twig' with {
                'form': form,
                'button_label': 'Mettre à jour'
            } %}
        </div>
    </div>
</div>
{% endblock %}
