{# Formulaire réutilisable pour créer/éditer un établissement #}

<div class="card shadow-sm border-0 rounded-3">
    <div class="card-body p-4">
        
        {{ form_start(form, {'attr': {'class': 'needs-validation', 'novalidate': true}}) }}

        <div class="row">
            {# NOM #}
            <div class="col-md-6 mb-3">
                <label for="etablissement_nom" class="form-label fw-semibold">
                    <i class="fa fa-building"></i> Nom de l'établissement
                </label>
                {{ form_widget(form.nom, {
                    'attr': {
                        'class': 'form-control',
                        'placeholder': 'Ex: Lycée Henri Matisse'
                    }
                }) }}
                {{ form_errors(form.nom) }}
            </div>

            {# VILLE #}
            <div class="col-md-6 mb-3">
                <label for="etablissement_ville" class="form-label fw-semibold">
                    <i class="fa fa-map-pin"></i> Ville
                </label>
                {{ form_widget(form.ville, {
                    'attr': {
                        'class': 'form-control',
                        'placeholder': 'Ex: Lomé'
                    }
                }) }}
                {{ form_errors(form.ville) }}
            </div>
        </div>

        {# ADRESSE #}
        <div class="mb-3">
            <label for="etablissement_adresse" class="form-label fw-semibold">
                <i class="fa fa-home"></i> Adresse
            </label>
            {{ form_widget(form.adresse, {
                'attr': {
                    'class': 'form-control',
                    'placeholder': 'Ex: 123 Rue de la Paix'
                }
            }) }}
            {{ form_errors(form.adresse) }}
        </div>

        <div class="row">
            {# TÉLÉPHONE #}
            <div class="col-md-6 mb-3">
                <label for="etablissement_telephone" class="form-label fw-semibold">
                    <i class="fa fa-phone"></i> Téléphone
                </label>
                {{ form_widget(form.telephone, {
                    'attr': {
                        'class': 'form-control',
                        'placeholder': '+228 XXXX XXXX'
                    }
                }) }}
                {{ form_errors(form.telephone) }}
            </div>

            {# EMAIL #}
            <div class="col-md-6 mb-3">
                <label for="etablissement_email" class="form-label fw-semibold">
                    <i class="fa fa-envelope"></i> Email
                </label>
                {{ form_widget(form.email, {
                    'attr': {
                        'class': 'form-control',
                        'placeholder': 'contact@etablissement.fr'
                    }
                }) }}
                {{ form_errors(form.email) }}
            </div>
        </div>

        {# IMAGE URL #}
        <div class="mb-3">
            <label for="etablissement_imageUrl" class="form-label fw-semibold">
                🖼️ URL Image (Google Images)
            </label>
            {{ form_widget(form.imageUrl, {
                'attr': {
                    'class': 'form-control',
                    'placeholder': 'https://example.com/image.jpg'
                }
            }) }}
            <small class="text-muted d-block mt-2">
                💡 Conseil: Cliquez droit sur une image Google Images → Copier l\'adresse
            </small>
            {{ form_errors(form.imageUrl) }}
        </div>

        {# APERÇU IMAGE #}
        <div id="imagePreview" class="mb-3" style="display:none;">
            <label class="form-label fw-semibold">Aperçu de l'image:</label>
            <div class="card border-light">
                <img id="previewImg" src="" alt="Aperçu" class="card-img-top" style="max-height: 250px; object-fit: cover;">
            </div>
        </div>

        {# BOUTONS #}
        <div class="d-flex gap-2 justify-content-end mt-4">
            <a href="{{ path('etablissement_index') }}" class="btn btn-outline-secondary">
                <i class="fa fa-times"></i> Annuler
            </a>
            <button type="submit" class="btn btn-primary">
                <i class="fa fa-save"></i> {{ button_label|default('Enregistrer') }}
            </button>
        </div>

        {{ form_end(form) }}

    </div>
</div>

<script>
document.addEventListener('DOMContentLoaded', function() {
    const imageInput = document.querySelector('input[name="etablissement_type[imageUrl]"]');
    const imagePreview = document.getElementById('imagePreview');
    const previewImg = document.getElementById('previewImg');
    
    if (imageInput) {
        imageInput.addEventListener('change', function() {
            const url = this.value.trim();
            if (url) {
                previewImg.src = url;
                imagePreview.style.display = 'block';
            } else {
                imagePreview.style.display = 'none';
            }
        });
        
        // Afficher si l'image existe déjà
        if (imageInput.value) {
            previewImg.src = imageInput.value;
            imagePreview.style.display = 'block';
        }
    }
});
</script>
