{% extends 'base.html.twig' %}

{% block title %}Nos Établissements Partenaires{% endblock %}

{% block body %}
<div class="container py-5 mt-5">
    <div class="text-center mb-5">
        <h1 class="display-4 fw-bold text-dark">Nos Établissements</h1>
        <p class="lead text-muted">Découvrez notre réseau mondial d'institutions partenaires.</p>
    </div>

    <div class="row row-cols-1 row-cols-md-2 row-cols-lg-4 g-4">
        {% for e in etablissements %}
            <div class="col">
                <div class="card h-100 shadow-sm border-0 transition-hover">
                    <div class="card-body">
                        <h5 class="card-title fw-bold text-primary">{{ e.nom }}</h5>
                        <h6 class="card-subtitle mb-2 text-muted">
                            <i class="fa fa-map-marker-alt"></i> {{ e.ville }}
                        </h6>
                        <p class="card-text small mt-3">{{ e.desc }}</p>
                    </div>
                    <div class="card-footer bg-white border-0 pb-3">
                        <a href="#" class="btn btn-outline-primary btn-sm w-100">Explorer</a>
                    </div>
                </div>
            </div>
        {% else %}
            <div class="col-12 text-center">
                <p class="text-muted">Aucun établissement répertorié pour le moment.</p>
            </div>
        {% endfor %}
    </div>
</div>
{% endblock %}