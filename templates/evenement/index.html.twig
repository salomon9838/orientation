{% extends 'base.html.twig' %}

{% block title %}Evenement index{% endblock %}

{% block stylesheets %}
    {{ parent() }}

    <!-- Bootstrap 5 -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
{% endblock %}

{% block body %}
<div class="container py-5">

    <div class="card shadow border-0 rounded-3">
        <div class="card-body p-4">

            <h2 class="text-center fw-bold text-primary mb-4">
                Liste des événements
            </h2>

            <div class="table-responsive">
                <table class="table table-striped table-hover align-middle text-center">
                    <thead class="table-primary">
                        <tr>
                            <th>Id</th>
                            <th>Titre</th>
                            <th>Description</th>
                            <th>Date début</th>
                            <th>Date fin</th>
                            <th>Lieu</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                    {% for evenement in evenements %}
                        <tr>
                            <td>{{ evenement.id }}</td>
                            <td class="fw-semibold">{{ evenement.titre }}</td>
                            <td>{{ evenement.description }}</td>
                            <td>
                                {{ evenement.dateDebut|date('d/m/Y H:i') }}
                            </td>
                            <td>
                                {{ evenement.dateDebut|date('d/m/Y H:i') }}
                            </td>
                            <td>{{ evenement.lieu }}</td>
                            <td>
                                <a href="{{ path('app_evenement_show', {'id': evenement.id}) }}" class="btn btn-sm btn-outline-primary me-1">
                                    Voir
                                </a>
                                <a href="{{ path('app_evenement_edit', {'id': evenement.id}) }}" class="btn btn-sm btn-outline-warning">
                                    Modifier
                                </a>
                            </td>
                        </tr>
                    {% else %}
                        <tr>
                            <td colspan="7" class="text-muted">Aucun enregistrement trouvé</td>
                        </tr>
                    {% endfor %}
                    </tbody>
                </table>
            </div>

            <div class="d-flex justify-content-end mt-3">
                <a href="{{ path('app_evenement_new') }}" class="btn btn-success">
                    + Créer un événement
                </a>
            </div>

        </div>
    </div>

</div>
{% endblock %}