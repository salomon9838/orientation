{% extends 'base.html.twig' %}

{% block title %}Événements - SchoolPrepar{% endblock %}

{% block body %}
<div class="container py-5 mt-5">
    
    <div class="text-center mb-5">
        <h1 class="display-5 fw-bold text-primary">Événements à venir</h1>
        <p class="text-muted">Participez à nos événements pour découvrir les filières et les établissements.</p>
    </div>

    <div class="row g-4">
        {% for evenement in evenements %}
            <div class="col-md-6 col-lg-4">
                <div class="card h-100 shadow-sm border-0 transition-hover">
                    {% if evenement.imageUrl %}
                        <img src="{{ evenement.imageUrl }}" alt="{{ evenement.titre }}" class="card-img-top img-fluid" style="height: 200px; object-fit: cover;">
                    {% else %}
                        <div class="d-flex align-items-center justify-content-center bg-light" style="height: 200px;">
                            <i class="fas fa-calendar-alt fa-3x text-muted opacity-50"></i>
                        </div>
                    {% endif %}
                    <div class="card-body">
                        <h4 class="fw-bold text-dark mb-2">{{ evenement.titre }}</h4>
                        <div class="mb-3 text-muted small">
                            <div class="mb-1">
                                <i class="fas fa-map-marker-alt me-2"></i>{{ evenement.lieu }}
                            </div>
                            <div class="mb-1">
                                <i class="fas fa-calendar me-2"></i>
                                Du {{ evenement.dateDebut|date('d/m/Y H:i') }}
                            </div>
                            <div class="mb-2">
                                <i class="fas fa-clock me-2"></i>
                                Au {{ evenement.dateFin|date('d/m/Y H:i') }}
                            </div>
                        </div>
                        <p class="text-muted small" style="text-align: justify;">
                            {{ evenement.description|length > 120 ? evenement.description|slice(0, 120) ~ '...' : evenement.description }}
                        </p>
                    </div>
                    <div class="card-footer bg-white border-0 p-3">
                        <a href="{{ path('app_evenement_show', {'id': evenement.id}) }}" class="btn btn-outline-primary w-100 fw-bold">
                            Voir détails
                        </a>
                    </div>
                </div>
            </div>
        {% else %}
            <div class="col-12 text-center">
                <p class="text-muted">Aucun événement n'est actuellement disponible.</p>
            </div>
        {% endfor %}
    </div>

</div>
{% endblock %}
