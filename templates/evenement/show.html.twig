{% extends 'base.html.twig' %}

{% block title %}Evenement{% endblock %}

{% block stylesheets %}
    {{ parent() }}

    <!-- Bootstrap 5 -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
{% endblock %}

{% block body %}
<div class="container py-5">

    <div class="row justify-content-center">
        <div class="col-lg-8">

            <div class="card shadow border-0 rounded-3">
                <div class="card-body p-5">

                    <h2 class="text-center fw-bold text-primary mb-4">
                        Détails de l'événement
                    </h2>

                    <div class="table-responsive">
                        <table class="table table-bordered align-middle">
                            <tbody>
                                <tr>
                                    <th class="table-light w-25">Id</th>
                                    <td>{{ evenement.id }}</td>
                                </tr>
                                <tr>
                                    <th class="table-light">Titre</th>
                                    <td class="fw-semibold">{{ evenement.titre }}</td>
                                </tr>
                                <tr>
                                    <th class="table-light">Description</th>
                                    <td>{{ evenement.description }}</td>
                                </tr>
                                <tr>
                                    <th class="table-light">Date début</th>
                                    {{ evenement.dateDebut|date('d/m/Y H:i') }}
                                </tr>
                                <tr>
                                    <th class="table-light">Date fin</th>
                                   {{ evenement.dateDebut|date('d/m/Y H:i') }}
                                </tr>
                                <tr>
                                    <th class="table-light">Lieu</th>
                                    <td>{{ evenement.lieu }}</td>
                                </tr>
                            </tbody>
                        </table>
                    </div>

                    <div class="d-flex justify-content-between mt-4">

                        <a href="{{ path('app_evenement_index') }}" class="btn btn-outline-secondary">
                            ← Retour
                        </a>

                        <div>
                            <a href="{{ path('app_evenement_edit', {'id': evenement.id}) }}" class="btn btn-warning me-2">
                                Modifier
                            </a>

                            {{ include('evenement/_delete_form.html.twig') }}
                        </div>

                    </div>

                </div>
            </div>

        </div>
    </div>

</div>
{% endblock %}