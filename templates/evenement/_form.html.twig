{{ form_start(form) }}

<div class="row g-3">

    <div class="col-12">
        {{ form_label(form.titre, null, {'label_attr': {'class': 'form-label fw-semibold'}}) }}
        {{ form_widget(form.titre, {'attr': {'class': 'form-control'}}) }}
        {{ form_errors(form.titre) }}
    </div>

    <div class="col-12">
        {{ form_label(form.description, null, {'label_attr': {'class': 'form-label fw-semibold'}}) }}
        {{ form_widget(form.description, {'attr': {'class': 'form-control', 'rows': 4}}) }}
        {{ form_errors(form.description) }}
    </div>

    <div class="col-md-6">
        {{ form_label(form.dateDebut, null, {'label_attr': {'class': 'form-label fw-semibold'}}) }}
        {{ form_widget(form.dateDebut, {'attr': {'class': 'form-control'}}) }}
        {{ form_errors(form.dateDebut) }}
    </div>

    <div class="col-md-6">
        {{ form_label(form.dateFin, null, {'label_attr': {'class': 'form-label fw-semibold'}}) }}
        {{ form_widget(form.dateFin, {'attr': {'class': 'form-control'}}) }}
        {{ form_errors(form.dateFin) }}
    </div>

    <div class="col-12">
        {{ form_label(form.lieu, null, {'label_attr': {'class': 'form-label fw-semibold'}}) }}
        {{ form_widget(form.lieu, {'attr': {'class': 'form-control'}}) }}
        {{ form_errors(form.lieu) }}
    </div>

    <div class="col-md-6">
        {{ form_label(form.etablissement, null, {'label_attr': {'class': 'form-label fw-semibold'}}) }}
        {{ form_widget(form.etablissement, {'attr': {'class': 'form-select'}}) }}
        {{ form_errors(form.etablissement) }}
    </div>

    <div class="col-md-6">
        {{ form_label(form.utilisateurs, null, {'label_attr': {'class': 'form-label fw-semibold'}}) }}
        {{ form_widget(form.utilisateurs, {'attr': {'class': 'form-select'}}) }}
        {{ form_errors(form.utilisateurs) }}
    </div>

</div>

<div class="d-flex justify-content-between mt-4">

    <a href="{{ path('app_evenement_index') }}" class="btn btn-outline-secondary">
        ← Retour
    </a>

    <button class="btn btn-primary px-4">
        {{ button_label|default('Save') }}
    </button>

</div>

{{ form_end(form) }}