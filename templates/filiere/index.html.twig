{% extends 'base.html.twig' %}

{% block title %}Nos Filières - SchoolPrepar{% endblock %}

{% block body %}
<div class="container py-5 mt-5">
    
    <div class="text-center mb-5">
        <h1 class="display-5 fw-bold text-primary">Nos Filières</h1>
        <p class="text-muted">Choisissez votre domaine d'étude parmi nos formations disponibles.</p>
    </div>

    <div class="row g-4">
        {% for filiere in filieres %}
            <div class="col-md-6 col-lg-3">
                <div class="card h-100 shadow-sm border-0 transition-hover">
                    {% if filiere.imageUrl %}
                        <img src="{{ filiere.imageUrl }}" alt="{{ filiere.nom }}" class="card-img-top img-fluid" style="height: 200px; object-fit: cover;">
                    {% else %}
                        <img src="{{ asset('assets/img/portfolio/2.jpg') }}" alt="Aperçu de la filière" class="card-img-top img-fluid" style="height: 200px; object-fit: cover;">
                    {% endif %}
                    <div class="card-body">
                        <h4 class="fw-bold text-dark mb-3">{{ filiere.nom }}</h4>
                        <p class="text-muted small" style="text-align: justify;">
                            {{ filiere.description|length > 100 ? filiere.description|slice(0, 100) ~ '...' : filiere.description }}
                        </p>
                    </div>
                    <div class="card-footer bg-white border-0 p-3">
                        <a href="{{ path('filiere_show', {'id': filiere.id}) }}" class="btn btn-outline-primary w-100 fw-bold">
                            Voir détails
                        </a>
                    </div>
                </div>
            </div>
        {% else %}
            <div class="col-12 text-center">
                <p class="text-muted">Aucune filière n'est actuellement disponible.</p>
            </div>
        {% endfor %}
    </div>

</div>
{% endblock %}