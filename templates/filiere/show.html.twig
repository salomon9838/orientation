{% extends 'base.html.twig' %}

{% block title %}{{ filiere.nom }} - SchoolPrepar{% endblock %}

{% block body %}
<div class="container py-5 mt-5">

    {# Fil d'Ariane #}
    <nav aria-label="breadcrumb" class="mb-5">
        <ol class="breadcrumb bg-light p-3 rounded shadow-sm">
            <li class="breadcrumb-item"><a href="{{ path('home') }}" class="text-decoration-none">Accueil</a></li>
            <li class="breadcrumb-item"><a href="{{ path('filieres') }}" class="text-decoration-none">Filières</a></li>
            <li class="breadcrumb-item active fw-bold" aria-current="page">{{ filiere.nom }}</li>
        </ol>
    </nav>

    <div class="row g-5">
        {# Colonne Principale #}
        <div class="col-lg-8">
            <div class="mb-5">
                <h1 class="display-5 fw-bold text-primary mb-3">{{ filiere.nom }}</h1>
                <hr class="w-25 border-primary border-3 opacity-100 mb-4">
                <p class="lead text-secondary" style="text-align: justify;">
                    {{ filiere.description|nl2br }}
                </p>
            </div>

            {# Conditions d'admission #}
            <div class="card border-0 shadow-sm mb-5">
                <div class="card-header bg-white py-3 border-bottom border-light">
                    <h2 class="h4 fw-bold mb-0 text-dark">🎓 Conditions d'admission</h2>
                </div>
                <div class="card-body p-4 bg-light">
                    <p class="mb-0 fs-5 text-dark">
                        {{ filiere.conditionsAdmission|default('Contactez-nous pour connaître les critères d\'admission spécifiques.') }}
                    </p>
                </div>
            </div>

            {# Débouchés #}
            <div class="card border-0 shadow-sm">
                <div class="card-header bg-white py-3 border-bottom border-light">
                    <h2 class="h4 fw-bold mb-0 text-success">💼 Débouchés professionnels</h2>
                </div>
                <div class="card-body p-4">
                    <ul class="list-group list-group-flush">
                        {% for debouche in filiere.debouches %}
                            <li class="list-group-item d-flex align-items-center bg-transparent border-0 py-2">
                                <span class="me-3 text-success fs-4">✔</span>
                                <span class="fw-medium">{{ debouche }}</span>
                            </li>
                        {% else %}
                            <li class="list-group-item text-muted italic">Aucun débouché renseigné pour le moment.</li>
                        {% endfor %}
                    </ul>
                </div>
            </div>
        </div>

        {# Colonne Latérale #}
        <div class="col-lg-4">
            {# Liste des écoles #}
            <div class="card border-0 shadow-sm mb-4">
                <div class="card-header bg-dark text-white fw-bold py-3 text-center">
                    🏫 Écoles proposant cette filière
                </div>
                <div class="list-group list-group-flush">
                    {% for ecole in filiere.ecoles %}
                        <div class="list-group-item d-flex justify-content-between align-items-center p-3">
                            <span class="fw-semibold">{{ ecole.nom }}</span>
                            {# Correction : Ajout d'une condition pour le lien #}
                            {% if ecole.id is defined %}
                                <a href="{{ path('filiere_show', {'id': ecole.id}) }}" class="btn btn-sm btn-outline-primary">Détails</a>
                            {% else %}
                                <span class="text-muted small">N/A</span>
                            {% endif %}
                        </div>
                    {% else %}
                        <div class="list-group-item text-center text-muted">Aucune école trouvée.</div>
                    {% endfor %}
                </div>
            </div>

            {# Bloc Localisation #}
            <div class="card border-0 shadow-sm">
                <div class="card-body">
                    <h5 class="fw-bold mb-3"><i class="fa fa-map-marker-alt text-danger me-2"></i>Localisation</h5>
                    <div class="ratio ratio-16x9 rounded overflow-hidden border">
                        <img src="{{ asset('assets/img/home-office.png') }}" class="img-fluid" alt="Localisation" style="object-fit: cover;">
                    </div>
                </div>
            </div>

            {# Appel à l'action #}
            <div class="mt-4 p-4 bg-primary text-white rounded shadow-sm text-center">
                <h5 class="fw-bold">Besoin d'aide ?</h5>
                <p class="small">Nos conseillers vous accompagnent dans votre choix d'orientation.</p>
            
            </div>
        </div>
    </div>
</div>
{% endblock %}