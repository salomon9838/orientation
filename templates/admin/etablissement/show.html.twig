{% extends 'admin/base.html.twig' %}

{% block title %}Détails Établissement - SchoolPrepar{% endblock %}

{% block admin_content %}
<div class="container-fluid">

    <div class="admin-page-header">
        <div class="d-flex align-items-center">
            <a href="{{ path('admin_etablissement') }}" class="btn btn-outline-secondary me-3">
                <i class="fas fa-arrow-left"></i>
            </a>
            <div>
                <h1><i class="fas fa-university"></i>Détails de l'Établissement</h1>
                <p>Consultez et gérez les informations de cet établissement</p>
            </div>
        </div>
    </div>

    <div class="row">
        <div class="col-lg-4 mb-4">
            <div class="admin-card">
                <div class="admin-card-header">
                    <h5><i class="fas fa-image me-2"></i>Photo</h5>
                </div>
                <div class="card-body text-center">
                    {% if etablissement.imageUrl %}
                        <img src="{{ etablissement.imageUrl }}" alt="{{ etablissement.nom }}" class="img-fluid rounded-4 mb-3" style="max-height: 250px; object-fit: cover;">
                    {% else %}
                        <div class="d-flex align-items-center justify-content-center bg-light rounded-4 mb-3" style="height: 250px;">
                            <i class="fas fa-university fa-4x text-muted opacity-25"></i>
                        </div>
                        <p class="text-muted mb-0">Aucune photo disponible</p>
                    {% endif %}
                </div>
            </div>
            
            <div class="admin-card">
                <div class="admin-card-header">
                    <h5><i class="fas fa-chart-bar me-2"></i>Statistiques</h5>
                </div>
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center mb-3">
                        <span class="text-muted"><i class="fas fa-graduation-cap me-2"></i>Filières</span>
                        <span class="fw-bold">{{ etablissement.filieres|length }}</span>
                    </div>
                    <div class="d-flex justify-content-between align-items-center mb-3">
                        <span class="text-muted"><i class="fas fa-calendar-alt me-2"></i>Événements</span>
                        <span class="fw-bold">{{ etablissement.evenements|length }}</span>
                    </div>
                    <div class="d-flex justify-content-between align-items-center">
                        <span class="text-muted"><i class="fas fa-users me-2"></i>Étudiants</span>
                        <span class="fw-bold">0</span>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-lg-8">
            <div class="admin-card mb-4">
                <div class="admin-card-header d-flex justify-content-between align-items-center">
                    <h5><i class="fas fa-info-circle me-2"></i>Informations générales</h5>
                    <span class="badge-status badge-active">Actif</span>
                </div>
                <div class="card-body">
                    <div class="row">
                        <div class="col-md-6 mb-4">
                            <label class="form-label fw-semibold text-muted">Nom de l'établissement</label>
                            <h5 class="mb-0">{{ etablissement.nom }}</h5>
                        </div>
                        <div class="col-md-6 mb-4">
                            <label class="form-label fw-semibold text-muted">Ville</label>
                            <h5 class="mb-0">{{ etablissement.ville }}</h5>
                        </div>
                        <div class="col-md-6 mb-4">
                            <label class="form-label fw-semibold text-muted">Téléphone</label>
                            <h5 class="mb-0">{{ etablissement.telephone }}</h5>
                        </div>
                        <div class="col-md-6 mb-4">
                            <label class="form-label fw-semibold text-muted">Email</label>
                            <h5 class="mb-0">{{ etablissement.email }}</h5>
                        </div>
                        <div class="col-12 mb-4">
                            <label class="form-label fw-semibold text-muted">Adresse complète</label>
                            <p class="mb-0">{{ etablissement.adresse }}</p>
                        </div>
                    </div>
                </div>
            </div>

            <div class="admin-card">
                <div class="admin-card-header">
                    <h5><i class="fas fa-cog me-2"></i>Actions</h5>
                </div>
                <div class="card-body">
                    <div class="d-flex flex-wrap gap-2">
                        <a href="{{ path('admin_etablissement_edit', {'id': etablissement.id}) }}" class="btn btn-admin-warning">
                            <i class="fas fa-edit me-2"></i>Modifier
                        </a>
                        <a href="{{ path('admin_etablissement') }}" class="btn btn-outline-secondary">
                            <i class="fas fa-arrow-left me-2"></i>Retour à la liste
                        </a>
                        <form method="POST" action="{{ path('admin_etablissement_delete', {'id': etablissement.id}) }}" class="ms-auto" onsubmit="return confirm('Voulez-vous vraiment supprimer cet établissement ? Cette action est irréversible et supprimera également toutes les filières et événements associés.');">
                            <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ etablissement.id) }}">
                            <button type="submit" class="btn btn-admin-danger">
                                <i class="fas fa-trash me-2"></i>Supprimer
                            </button>
                        </form>
                    </div>
                </div>
            </div>

            {% if etablissement.filieres|length > 0 %}
            <div class="admin-card mt-4">
                <div class="admin-card-header">
                    <h5><i class="fas fa-graduation-cap me-2"></i>Filières associées</h5>
                </div>
                <div class="card-body p-0">
                    <div class="table-responsive">
                        <table class="table admin-table mb-0">
                            <thead>
                                <tr>
                                    <th>Nom</th>
                                    <th>Description</th>
                                    <th class="text-center">Actions</th>
                                </tr>
                            </thead>
                            <tbody>
                            {% for filiere in etablissement.filieres %}
                                <tr>
                                    <td><strong>{{ filiere.nom }}</strong></td>
                                    <td>{{ filiere.description|length > 50 ? filiere.description|slice(0, 50) ~ '...' : filiere.description }}</td>
                                    <td class="text-center">
                                        <a href="{{ path('admin_filiere_show', {'id': filiere.id}) }}" class="btn-action btn-view">
                                            <i class="fas fa-eye"></i>
                                        </a>
                                    </td>
                                </tr>
                            {% endfor %}
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
            {% endif %}
        </div>
    </div>

</div>
{% endblock %}