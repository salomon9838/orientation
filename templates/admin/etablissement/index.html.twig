{% extends 'admin/base.html.twig' %}

{% block title %}Gestion des Établissements{% endblock %}

{% block body %}
<div class="container-fluid">

    <!-- HEADER -->
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h3 class="fw-bold">Gestion des Établissements</h3>

        <a href="{{ path('etablissement_index') }}" class="btn btn-success">
            + Ajouter un établissement
        </a>
    </div>

    <!-- MESSAGE FLASH -->
    {% for message in app.flashes('success') %}
        <div class="alert alert-success">
            {{ message }}
        </div>
    {% endfor %}

    <!-- TABLE -->
    <div class="card shadow-sm">
        <div class="card-body p-0">

            <div class="table-responsive">
                <table class="table table-hover mb-0">

                    <thead class="table-light">
                        <tr>
                            <th>ID</th>
                            <th>Nom</th>
                            <th>Ville</th>
                            <th class="text-center">Actions</th>
                        </tr>
                    </thead>

                    <tbody>

                    {% for etab in etablissements %}
                        <tr>
                            <td>{{ etab.id }}</td>

                            <td>
                                <strong>{{ etab.nom }}</strong>
                            </td>

                            <td>{{ etab.ville }}</td>

                            <td class="text-center">

                                <a href="{{ path('etablissement_index', {'id': etab.id}) }}"
                                   class="btn btn-sm btn-outline-primary me-1">
                                    Voir
                                </a>

                                <a href="{{ path('etablissement_index', {'id': etab.id}) }}"
                                   class="btn btn-sm btn-outline-warning me-1">
                                    Modifier
                                </a>

                                <a href="{{ path('etablissement_index', {'id': etab.id}) }}"
                                   class="btn btn-sm btn-outline-danger"
                                   onclick="return confirm('Voulez-vous supprimer cet établissement ?')">
                                    Supprimer
                                </a>

                            </td>
                        </tr>

                    {% else %}
                        <tr>
                            <td colspan="4" class="text-center py-4 text-muted">
                                Aucun établissement trouvé
                            </td>
                        </tr>
                    {% endfor %}

                    </tbody>

                </table>
            </div>

        </div>
    </div>

</div>
{% endblock %}