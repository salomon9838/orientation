{% extends 'admin/base.html.twig' %}

{% block title %}Modifier Établissement - SchoolPrepar{% endblock %}

{% block admin_content %}
<div class="container-fluid">

    <div class="admin-page-header">
        <div class="d-flex align-items-center">
            <a href="{{ path('admin_etablissement') }}" class="btn btn-outline-secondary me-3">
                <i class="fas fa-arrow-left"></i>
            </a>
            <div>
                <h1><i class="fas fa-university"></i>Modifier l'Établissement</h1>
                <p>Modifiez les informations de l'établissement: {{ etablissement.nom }}</p>
            </div>
        </div>
    </div>

    <div class="row">
        <div class="col-lg-8">
            <div class="admin-card">
                <div class="admin-card-header">
                    <h5><i class="fas fa-edit me-2"></i>Modifier les informations</h5>
                </div>
                <div class="card-body">
                    {{ form_start(form, {'attr': {'novalidate': 'novalidate'}}) }}

                    <div class="row">
                        <div class="col-md-12 mb-4">
                            {{ form_label(form.nom, null, {'label_attr': {'class': 'form-label fw-semibold'}}) }}
                            {{ form_widget(form.nom, {'attr': {'class': 'form-control'}}) }}
                            {{ form_errors(form.nom) }}
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-md-6 mb-4">
                            {{ form_label(form.ville, null, {'label_attr': {'class': 'form-label fw-semibold'}}) }}
                            {{ form_widget(form.ville, {'attr': {'class': 'form-control'}}) }}
                            {{ form_errors(form.ville) }}
                        </div>
                        <div class="col-md-6 mb-4">
                            {{ form_label(form.telephone, null, {'label_attr': {'class': 'form-label fw-semibold'}}) }}
                            {{ form_widget(form.telephone, {'attr': {'class': 'form-control'}}) }}
                            {{ form_errors(form.telephone) }}
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-md-12 mb-4">
                            {{ form_label(form.adresse, null, {'label_attr': {'class': 'form-label fw-semibold'}}) }}
                            {{ form_widget(form.adresse, {'attr': {'class': 'form-control'}}) }}
                            {{ form_errors(form.adresse) }}
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-md-12 mb-4">
                            {{ form_label(form.email, null, {'label_attr': {'class': 'form-label fw-semibold'}}) }}
                            {{ form_widget(form.email, {'attr': {'class': 'form-control'}}) }}
                            {{ form_errors(form.email) }}
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-md-12 mb-4">
                            {{ form_label(form.imageFile, null, {'label_attr': {'class': 'form-label fw-semibold'}}) }}
                            {% if etablissement.imageUrl %}
                                <div class="mb-3">
                                    <img src="{{ etablissement.imageUrl }}" alt="{{ etablissement.nom }}" class="img-thumbnail" style="max-height: 150px;">
                                </div>
                                <small class="text-muted d-block mb-2">Photo actuelle - téléchargez une nouvelle image pour la remplacer</small>
                            {% endif %}
                            {{ form_widget(form.imageFile, {'attr': {'class': 'form-control'}}) }}
                            {{ form_errors(form.imageFile) }}
                        </div>
                    </div>

                    <hr class="my-4">

                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-admin-warning">
                            <i class="fas fa-save me-2"></i>Enregistrer les modifications
                        </button>
                        <a href="{{ path('admin_etablissement') }}" class="btn btn-outline-secondary">
                            <i class="fas fa-times me-2"></i>Annuler
                        </a>
                    </div>

                    {{ form_end(form) }}
                </div>
            </div>
        </div>

        <div class="col-lg-4">
            <div class="admin-card mb-4">
                <div class="admin-card-header">
                    <h5><i class="fas fa-info-circle me-2"></i>Informations</h5>
                </div>
                <div class="card-body">
                    <ul class="list-unstyled mb-0">
                        <li class="mb-3">
                            <strong>ID:</strong> #{{ etablissement.id }}
                        </li>
                        <li class="mb-3">
                            <strong>Nom:</strong> {{ etablissement.nom }}
                        </li>
                        <li class="mb-3">
                            <strong>Ville:</strong> {{ etablissement.ville }}
                        </li>
                        <li>
                            <strong>Email:</strong> {{ etablissement.email }}
                        </li>
                    </ul>
                </div>
            </div>

            <div class="admin-card">
                <div class="admin-card-header">
                    <h5><i class="fas fa-lightbulb me-2"></i>Astuces</h5>
                </div>
                <div class="card-body">
                    <ul class="list-unstyled mb-0">
                        <li class="mb-3">
                            <i class="fas fa-check-circle text-success me-2"></i>
                            Vérifiez toutes les informations avant de sauvegarder
                        </li>
                        <li class="mb-3">
                            <i class="fas fa-check-circle text-success me-2"></i>
                            Une nouvelle photo remplacera l'ancienne
                        </li>
                        <li>
                            <i class="fas fa-check-circle text-success me-2"></i>
                            Les modifications sont immédiatement enregistrées
                        </li>
                    </ul>
                </div>
            </div>
        </div>
    </div>

</div>
{% endblock %}