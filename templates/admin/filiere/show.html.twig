{% extends 'admin/base.html.twig' %}

{% block title %}Détails Filière - SchoolPrepar{% endblock %}

{% block admin_content %}
<div class="container-fluid">

    <div class="admin-page-header">
        <div class="d-flex align-items-center">
            <a href="{{ path('admin_filiere') }}" class="btn btn-outline-secondary me-3">
                <i class="fas fa-arrow-left"></i>
            </a>
            <div>
                <h1><i class="fas fa-graduation-cap"></i>Détails de la Filière</h1>
                <p>Consultez et gérez les informations de cette filière</p>
            </div>
        </div>
    </div>

    <div class="row">
        <div class="col-lg-4 mb-4">
            <div class="admin-card">
                <div class="admin-card-header">
                    <h5><i class="fas fa-image me-2"></i>Photo</h5>
                </div>
                <div class="card-body text-center">
                    {% if filiere.imageUrl %}
                        <img src="{{ filiere.imageUrl }}" alt="{{ filiere.nom }}" class="img-fluid rounded-4 mb-3" style="max-height: 250px; object-fit: cover;">
                    {% else %}
                        <div class="d-flex align-items-center justify-content-center bg-light rounded-4 mb-3" style="height: 250px;">
                            <i class="fas fa-book fa-3x text-muted opacity-25"></i>
                        </div>
                        <p class="text-muted mb-0">Aucune photo disponible</p>
                    {% endif %}
                </div>
            </div>
            
            <div class="admin-card">
                <div class="admin-card-header">
                    <h5><i class="fas fa-chart-bar me-2"></i>Statistiques</h5>
                </div>
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center mb-3">
                        <span class="text-muted"><i class="fas fa-users me-2"></i>Étudiants</span>
                        <span class="fw-bold">{{ filiere.utilisateurs|length }}</span>
                    </div>
                    <div class="d-flex justify-content-between align-items-center">
                        <span class="text-muted"><i class="fas fa-calendar me-2"></i>Créée le</span>
                        <span class="fw-bold">
                            {% if filiere.createdAt %}
                                {{ filiere.createdAt|date('d/m/Y') }}
                            {% else %}
                                -
                            {% endif %}
                        </span>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-lg-8">
            <div class="admin-card mb-4">
                <div class="admin-card-header d-flex justify-content-between align-items-center">
                    <h5><i class="fas fa-info-circle me-2"></i>Informations générales</h5>
                    <span class="badge-status badge-active">Active</span>
                </div>
                <div class="card-body">
                    <div class="row">
                        <div class="col-md-12 mb-4">
                            <label class="form-label fw-semibold text-muted">Nom de la filière</label>
                            <h5 class="mb-0">{{ filiere.nom }}</h5>
                        </div>
                        <div class="col-md-12 mb-4">
                            <label class="form-label fw-semibold text-muted">Description</label>
                            <p class="mb-0">{{ filiere.description }}</p>
                        </div>
                        <div class="col-md-12 mb-4">
                            <label class="form-label fw-semibold text-muted">Établissement</label>
                            <h5 class="mb-0">
                                {% if filiere.etablissement %}
                                    <i class="fas fa-university text-muted me-2"></i>{{ filiere.etablissement.nom }}
                                {% else %}
                                    <span class="text-muted">-</span>
                                {% endif %}
                            </h5>
                        </div>
                        <div class="col-md-12">
                            <label class="form-label fw-semibold text-muted">Date de création</label>
                            <p class="mb-0">
                                {% if filiere.createdAt %}
                                    <i class="fas fa-calendar text-muted me-2"></i>{{ filiere.createdAt|date('d/m/Y à H:i:s') }}
                                {% else %}
                                    -
                                {% endif %}
                            </p>
                        </div>
                    </div>
                </div>
            </div>

            <div class="admin-card">
                <div class="admin-card-header">
                    <h5><i class="fas fa-cog me-2"></i>Actions</h5>
                </div>
                <div class="card-body">
                    <div class="d-flex flex-wrap gap-2">
                        <a href="{{ path('admin_filiere_edit', {'id': filiere.id}) }}" class="btn btn-admin-warning">
                            <i class="fas fa-edit me-2"></i>Modifier
                        </a>
                        <a href="{{ path('admin_filiere') }}" class="btn btn-outline-secondary">
                            <i class="fas fa-arrow-left me-2"></i>Retour à la liste
                        </a>
                        <form method="POST" action="{{ path('admin_filiere_delete', {'id': filiere.id}) }}" class="ms-auto" onsubmit="return confirm('Voulez-vous vraiment supprimer cette filière ? Cette action est irréversible.');">
                            <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ filiere.id) }}">
                            <button type="submit" class="btn btn-admin-danger">
                                <i class="fas fa-trash me-2"></i>Supprimer
                            </button>
                        </form>
                    </div>
                </div>
            </div>

            {% if filiere.utilisateurs|length > 0 %}
            <div class="admin-card mt-4">
                <div class="admin-card-header">
                    <h5><i class="fas fa-users me-2"></i>Étudiants inscrits ({{ filiere.utilisateurs|length }})</h5>
                </div>
                <div class="card-body p-0">
                    <div class="table-responsive">
                        <table class="table admin-table mb-0">
                            <thead>
                                <tr>
                                    <th>Nom</th>
                                    <th>Prénom</th>
                                    <th>Email</th>
                                    <th class="text-center">Actions</th>
                                </tr>
                            </thead>
                            <tbody>
                            {% for utilisateur in filiere.utilisateurs %}
                                <tr>
                                    <td><strong>{{ utilisateur.nom }}</strong></td>
                                    <td>{{ utilisateur.prenom }}</td>
                                    <td>{{ utilisateur.email }}</td>
                                    <td class="text-center">
                                        <a href="{{ path('admin_utilisateur_show', {'id': utilisateur.id}) }}" class="btn-action btn-view">
                                            <i class="fas fa-eye"></i>
                                        </a>
                                    </td>
                                </tr>
                            {% endfor %}
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
            {% endif %}
        </div>
    </div>

</div>
{% endblock %}