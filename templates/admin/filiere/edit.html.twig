{% extends 'admin/base.html.twig' %}

{% block title %}Modifier Filière - SchoolPrepar{% endblock %}

{% block admin_content %}
<div class="container-fluid">

    <div class="admin-page-header">
        <div class="d-flex align-items-center">
            <a href="{{ path('admin_filiere') }}" class="btn btn-outline-secondary me-3">
                <i class="fas fa-arrow-left"></i>
            </a>
            <div>
                <h1><i class="fas fa-graduation-cap"></i>Modifier la Filière</h1>
                <p>Modifiez les informations de la filière: {{ filiere.nom }}</p>
            </div>
        </div>
    </div>

    <div class="row">
        <div class="col-lg-8">
            <div class="admin-card">
                <div class="admin-card-header">
                    <h5><i class="fas fa-edit me-2"></i>Modifier les informations</h5>
                </div>
                <div class="card-body">
                    {{ form_start(form, {'attr': {'novalidate': 'novalidate'}}) }}

                    <div class="row">
                        <div class="col-md-12 mb-4">
                            {{ form_label(form.nom, null, {'label_attr': {'class': 'form-label fw-semibold'}}) }}
                            {{ form_widget(form.nom, {'attr': {'class': 'form-control'}}) }}
                            {{ form_errors(form.nom) }}
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-md-12 mb-4">
                            {{ form_label(form.description, null, {'label_attr': {'class': 'form-label fw-semibold'}}) }}
                            {{ form_widget(form.description, {'attr': {'class': 'form-control'}}) }}
                            {{ form_errors(form.description) }}
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-md-12 mb-4">
                            {{ form_label(form.etablissement, null, {'label_attr': {'class': 'form-label fw-semibold'}}) }}
                            {{ form_widget(form.etablissement, {'attr': {'class': 'form-select'}}) }}
                            {{ form_errors(form.etablissement) }}
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-md-12 mb-4">
                            {{ form_label(form.imageFile, null, {'label_attr': {'class': 'form-label fw-semibold'}}) }}
                            {% if filiere.imageUrl %}
                                <div class="mb-3">
                                    <img src="{{ filiere.imageUrl }}" alt="{{ filiere.nom }}" class="img-thumbnail" style="max-height: 150px;">
                                </div>
                                <small class="text-muted d-block mb-2">Photo actuelle - téléchargez une nouvelle image pour la remplacer</small>
                            {% endif %}
                            {{ form_widget(form.imageFile, {'attr': {'class': 'form-control'}}) }}
                            {{ form_errors(form.imageFile) }}
                        </div>
                    </div>

                    <hr class="my-4">

                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-admin-warning">
                            <i class="fas fa-save me-2"></i>Enregistrer les modifications
                        </button>
                        <a href="{{ path('admin_filiere') }}" class="btn btn-outline-secondary">
                            <i class="fas fa-times me-2"></i>Annuler
                        </a>
                    </div>

                    {{ form_end(form) }}
                </div>
            </div>
        </div>

        <div class="col-lg-4">
            <div class="admin-card mb-4">
                <div class="admin-card-header">
                    <h5><i class="fas fa-info-circle me-2"></i>Informations</h5>
                </div>
                <div class="card-body">
                    <ul class="list-unstyled mb-0">
                        <li class="mb-3">
                            <strong>ID:</strong> #{{ filiere.id }}
                        </li>
                        <li class="mb-3">
                            <strong>Nom:</strong> {{ filiere.nom }}
                        </li>
                        <li class="mb-3">
                            <strong>Créée le:</strong> {% if filiere.createdAt %}{{ filiere.createdAt|date('d/m/Y') }}{% else %}-{% endif %}
                        </li>
                        <li>
                            <strong>Étudiants:</strong> {{ filiere.utilisateurs|length }}
                        </li>
                    </ul>
                </div>
            </div>

            <div class="admin-card">
                <div class="admin-card-header">
                    <h5><i class="fas fa-lightbulb me-2"></i>Astuces</h5>
                </div>
                <div class="card-body">
                    <ul class="list-unstyled mb-0">
                        <li class="mb-3">
                            <i class="fas fa-check-circle text-success me-2"></i>
                            Vérifiez toutes les informations avant de sauvegarder
                        </li>
                        <li class="mb-3">
                            <i class="fas fa-check-circle text-success me-2"></i>
                            Une nouvelle photo remplacera l'ancienne
                        </li>
                        <li>
                            <i class="fas fa-check-circle text-success me-2"></i>
                            Les modifications sont immédiatement enregistrées
                        </li>
                    </ul>
                </div>
            </div>
        </div>
    </div>

</div>
{% endblock %}