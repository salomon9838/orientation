{% extends 'admin/base.html.twig' %}

{% block title %}Gestion des filières{% endblock %}

{% block body %}

<div style="padding:30px;">

    <!-- HEADER -->
    <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:20px;">
        <h2>Gestion des filières</h2>

        <a href="#" style="background:#007bff;color:white;padding:10px 15px;border-radius:5px;text-decoration:none;">
            + Ajouter une filière
        </a>
    </div>

    <!-- MESSAGE FLASH -->
    {% for message in app.flashes('success') %}
        <div style="background:#d4edda;color:#155724;padding:10px;margin-bottom:15px;border-radius:5px;">
            {{ message }}
        </div>
    {% endfor %}

    <!-- TABLEAU -->
    <div style="background:white;padding:20px;border-radius:10px;box-shadow:0px 0px 10px rgba(0,0,0,0.1);">
        
        <table style="width:100%;border-collapse:collapse;">
            <thead style="background:#f8f9fa;">
                <tr>
                    <th style="padding:10px;border:1px solid #ddd;">ID</th>
                    <th style="padding:10px;border:1px solid #ddd;">Nom</th>
                    <th style="padding:10px;border:1px solid #ddd;">Description</th>
                    <th style="padding:10px;border:1px solid #ddd;">Actions</th>
                </tr>
            </thead>

            <tbody>

                {# Données simulées (remplaçables par base de données) #}
                {% set filieres = [
                    {'id':1,'nom':'Informatique','description':'Développement logiciel et applications'},
                    {'id':2,'nom':'Réseaux','description':'Administration réseaux et systèmes'},
                    {'id':3,'nom':'Télécommunications','description':'Communication et technologies modernes'}
                ] %}

                {% for filiere in filieres %}
                    <tr>
                        <td style="padding:10px;border:1px solid #ddd;">{{ filiere.id }}</td>
                        <td style="padding:10px;border:1px solid #ddd;">{{ filiere.nom }}</td>
                        <td style="padding:10px;border:1px solid #ddd;">{{ filiere.description }}</td>

                        <td style="padding:10px;border:1px solid #ddd;">

                            <a href="#" style="color:blue;margin-right:10px;">Voir</a>

                            <a href="#" style="color:orange;margin-right:10px;">Modifier</a>

                            <a href="#" style="color:red;"
                               onclick="return confirm('Voulez-vous supprimer cette filière ?');">
                                Supprimer
                            </a>

                        </td>
                    </tr>
                {% else %}
                    <tr>
                        <td colspan="4" style="text-align:center;padding:15px;">
                            Aucune filière trouvée
                        </td>
                    </tr>
                {% endfor %}

            </tbody>
        </table>

    </div>

</div>

{% endblock %}