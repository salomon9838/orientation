{% extends 'admin/base.html.twig' %}

{% block title %}Gestion des Filières{% endblock %}

{% block body %}
<div class="container-fluid">

    <!-- HEADER -->
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h3 class="fw-bold">Gestion des Filières</h3>

        <a href="{{ path('admin_filiere') }}" class="btn btn-primary">
            + Ajouter une filière
        </a>
    </div>

    <!-- TABLE -->
    <div class="card shadow-sm">
        <div class="card-body p-0">

            <div class="table-responsive">
                <table class="table table-hover mb-0">

                    <thead class="table-light">
                        <tr>
                            <th>#</th>
                            <th>Nom</th>
                            <th>Description</th>
                            <th>Niveau</th>
                            <th class="text-center">Actions</th>
                        </tr>
                    </thead>

                    <tbody>

                    {% for filiere in filieres %}
                        <tr>
                            <td>{{ filiere.id }}</td>

                            <td>
                                <strong>{{ filiere.nom }}</strong>
                            </td>

                            <td>{{ filiere.description }}</td>

                            <td>{{ filiere.niveau }}</td>

                            <td class="text-center">

                                <a href="{{ path('filiere_show', {'id': filiere.id}) }}"
                                   class="btn btn-sm btn-outline-primary me-1">
                                    Voir
                                </a>

                                <a href="{{ path('filiere_show', {'id': filiere.id}) }}"
                                   class="btn btn-sm btn-outline-warning me-1">
                                    Modifier
                                </a>

                                <a href="{{ path('filiere_show', {'id': filiere.id}) }}"
                                   class="btn btn-sm btn-outline-danger"
                                   onclick="return confirm('Supprimer cette filière ?')">
                                    Supprimer
                                </a>

                            </td>
                        </tr>

                    {% else %}
                        <tr>
                            <td colspan="5" class="text-center py-4 text-muted">
                                Aucune filière trouvée
                            </td>
                        </tr>
                    {% endfor %}

                    </tbody>

                </table>
            </div>

        </div>
    </div>

</div>
{% endblock %}