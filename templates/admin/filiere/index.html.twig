{% extends 'admin/base.html.twig' %}

{% block title %}Gestion des Filières - SchoolPrepar{% endblock %}

{% block admin_content %}
<div class="container-fluid">

    <div class="admin-page-header">
        <h1><i class="fas fa-graduation-cap"></i>Gestion des Filières</h1>
        <p>Gérez toutes les filières proposées par les établissements</p>
    </div>

    <div class="d-flex justify-content-between align-items-center mb-4">
        <div class="d-flex gap-2">
            <button class="btn btn-outline-secondary">
                <i class="fas fa-filter me-2"></i>Filtrer
            </button>
            <button class="btn btn-outline-secondary">
                <i class="fas fa-download me-2"></i>Exporter
            </button>
        </div>
        <a href="{{ path('admin_filiere_new') }}" class="btn btn-admin-primary">
            <i class="fas fa-plus me-2"></i>Nouvelle Filière
        </a>
    </div>

    <div class="admin-card">
        <div class="admin-card-header d-flex justify-content-between align-items-center">
            <h5><i class="fas fa-list me-2"></i>Liste des filières</h5>
            <span class="badge bg-primary">{{ filieres|length }} filière(s)</span>
        </div>
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table admin-table mb-0">
                    <thead>
                        <tr>
                            <th>ID</th>
                            <th>Nom</th>
                            <th>Description</th>
                            <th>Établissement</th>
                            <th class="text-center">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                    {% for filiere in filieres %}
                        <tr>
                            <td><span class="fw-semibold">#{{ filiere.id }}</span></td>
                            <td>
                                <div class="d-flex align-items-center">
                                    {% if filiere.imageUrl %}
                                        <img src="{{ filiere.imageUrl }}" alt="{{ filiere.nom }}" class="rounded-circle me-3" style="width: 40px; height: 40px; object-fit: cover;">
                                    {% else %}
                                        <div class="rounded-circle me-3 d-flex align-items-center justify-content-center" style="width: 40px; height: 40px; background: linear-gradient(135deg, #f97316 0%, #ea580c 100%);">
                                            <i class="fas fa-book text-white" style="font-size: 18px;"></i>
                                        </div>
                                    {% endif %}
                                    <strong class="text-dark">{{ filiere.nom }}</strong>
                                </div>
                            </td>
                            <td>{{ filiere.description|length > 50 ? filiere.description|slice(0, 50) ~ '...' : filiere.description }}</td>
                            <td>
                                {% if filiere.etablissement %}
                                    <i class="fas fa-university text-muted me-2"></i>{{ filiere.etablissement.nom }}
                                {% else %}
                                    <span class="text-muted">-</span>
                                {% endif %}
                            </td>
                            <td class="text-center">
                                <a href="{{ path('admin_filiere_show', {'id': filiere.id}) }}" class="btn-action btn-view">
                                    <i class="fas fa-eye"></i>
                                </a>
                                <a href="{{ path('admin_filiere_edit', {'id': filiere.id}) }}" class="btn-action btn-edit">
                                    <i class="fas fa-edit"></i>
                                </a>
                                <form method="POST" action="{{ path('admin_filiere_delete', {'id': filiere.id}) }}" class="d-inline" onsubmit="return confirm('Voulez-vous vraiment supprimer cette filière ? Cette action est irréversible.');">
                                    <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ filiere.id) }}">
                                    <button type="submit" class="btn-action btn-delete">
                                        <i class="fas fa-trash"></i>
                                    </button>
                                </form>
                            </td>
                        </tr>
                    {% else %}
                        <tr>
                            <td colspan="5" class="text-center py-5">
                                <div class="text-muted">
                                    <i class="fas fa-book fa-3x mb-3 opacity-25"></i>
                                    <h5 class="fw-semibold mb-2">Aucune filière trouvée</h5>
                                    <p class="mb-3">Commencez par ajouter votre première filière</p>
                                    <a href="{{ path('admin_filiere_new') }}" class="btn btn-admin-primary">
                                        <i class="fas fa-plus me-2"></i>Ajouter une filière
                                    </a>
                                </div>
                            </td>
                        </tr>
                    {% endfor %}
                    </tbody>
                </table>
            </div>
        </div>
    </div>

</div>
{% endblock %}