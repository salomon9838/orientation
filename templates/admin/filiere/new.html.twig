{% extends 'admin/base.html.twig' %}

{% block title %}Nouvelle Filière - SchoolPrepar{% endblock %}

{% block admin_content %}
<div class="container-fluid">

    <div class="admin-page-header">
        <div class="d-flex align-items-center">
            <a href="{{ path('admin_filiere') }}" class="btn btn-outline-secondary me-3">
                <i class="fas fa-arrow-left"></i>
            </a>
            <div>
                <h1><i class="fas fa-graduation-cap"></i>Créer une Nouvelle Filière</h1>
                <p>Ajoutez une nouvelle filière proposée par un établissement</p>
            </div>
        </div>
    </div>

    <div class="row">
        <div class="col-lg-8">
            <div class="admin-card">
                <div class="admin-card-header">
                    <h5><i class="fas fa-edit me-2"></i>Informations de la filière</h5>
                </div>
                <div class="card-body">
                    {{ form_start(form, {'attr': {'novalidate': 'novalidate'}}) }}

                    <div class="row">
                        <div class="col-md-12 mb-4">
                            {{ form_label(form.nom, null, {'label_attr': {'class': 'form-label fw-semibold'}}) }}
                            {{ form_widget(form.nom, {'attr': {'class': 'form-control'}}) }}
                            {{ form_errors(form.nom) }}
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-md-12 mb-4">
                            {{ form_label(form.description, null, {'label_attr': {'class': 'form-label fw-semibold'}}) }}
                            {{ form_widget(form.description, {'attr': {'class': 'form-control'}}) }}
                            {{ form_errors(form.description) }}
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-md-12 mb-4">
                            {{ form_label(form.etablissement, null, {'label_attr': {'class': 'form-label fw-semibold'}}) }}
                            {{ form_widget(form.etablissement, {'attr': {'class': 'form-select'}}) }}
                            {{ form_errors(form.etablissement) }}
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-md-12 mb-4">
                            {{ form_label(form.imageFile, null, {'label_attr': {'class': 'form-label fw-semibold'}}) }}
                            {{ form_widget(form.imageFile, {'attr': {'class': 'form-control'}}) }}
                            {{ form_errors(form.imageFile) }}
                        </div>
                    </div>

                    <hr class="my-4">

                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-admin-primary">
                            <i class="fas fa-save me-2"></i>Créer la filière
                        </button>
                        <a href="{{ path('admin_filiere') }}" class="btn btn-outline-secondary">
                            <i class="fas fa-times me-2"></i>Annuler
                        </a>
                    </div>

                    {{ form_end(form) }}
                </div>
            </div>
        </div>

        <div class="col-lg-4">
            <div class="admin-card">
                <div class="admin-card-header">
                    <h5><i class="fas fa-lightbulb me-2"></i>Astuces</h5>
                </div>
                <div class="card-body">
                    <ul class="list-unstyled mb-0">
                        <li class="mb-3">
                            <i class="fas fa-check-circle text-success me-2"></i>
                            Remplissez tous les champs obligatoires
                        </li>
                        <li class="mb-3">
                            <i class="fas fa-check-circle text-success me-2"></i>
                            Choisissez l'établissement qui propose cette filière
                        </li>
                        <li class="mb-3">
                            <i class="fas fa-check-circle text-success me-2"></i>
                            Utilisez une photo représentative de la filière
                        </li>
                        <li>
                            <i class="fas fa-check-circle text-success me-2"></i>
                            La description doit être claire et informative
                        </li>
                    </ul>
                </div>
            </div>
        </div>
    </div>

</div>
{% endblock %}