{# templates/admin/dashboard.html.twig #}
{% extends 'admin/base.html.twig' %}

{% block title %}Dashboard - SchoolPrepar{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.1/dist/chart.umd.min.js"></script>
    
    <style>
        .stat-card {
            border-radius: 16px;
            padding: 24px;
            transition: all 0.3s ease;
            border: none;
            box-shadow: 0 4px 20px rgba(0,0,0,0.08);
        }
        
        .stat-card:hover {
            transform: translateY(-5px);
            box-shadow: 0 8px 30px rgba(0,0,0,0.15);
        }
        
        .stat-icon {
            width: 60px;
            height: 60px;
            border-radius: 14px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 28px;
        }
        
        .stat-number {
            font-size: 32px;
            font-weight: 800;
            margin: 8px 0 4px 0;
        }
        
        .stat-label {
            font-size: 14px;
            opacity: 0.8;
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }
        
        .chart-card {
            border-radius: 16px;
            border: none;
            box-shadow: 0 4px 20px rgba(0,0,0,0.08);
            overflow: hidden;
        }
        
        .chart-card .card-header {
            background: linear-gradient(135deg, #1e40af 0%, #1e3a8a 100%);
            color: white;
            padding: 20px 24px;
            border: none;
        }
        
        .chart-card .card-body {
            padding: 24px;
        }
        
        .image-preview-card {
            border-radius: 16px;
            overflow: hidden;
            border: none;
            box-shadow: 0 4px 20px rgba(0,0,0,0.08);
            transition: all 0.3s ease;
        }
        
        .image-preview-card:hover {
            transform: translateY(-5px);
            box-shadow: 0 8px 30px rgba(0,0,0,0.15);
        }
        
        .image-preview-card img {
            height: 200px;
            object-fit: cover;
        }
        
        .trend-badge {
            padding: 4px 10px;
            border-radius: 20px;
            font-size: 12px;
            font-weight: 600;
        }
        
        .sparkline { 
            height: 68px !important; 
        }
    </style>
{% endblock %}

{% block admin_content %}
<div class="container-fluid">
    <div class="d-flex justify-content-between align-items-center mb-5">
        <div>
            <h1 class="h2 fw-bold text-dark mb-1">
                <i class="fas fa-chart-line me-2 text-primary"></i>Tableau de bord
            </h1>
            <p class="text-muted mb-0">Bienvenue sur SchoolPrepar Admin - {{ 'now'|date('d/m/Y') }}</p>
        </div>
        <div class="d-flex gap-2">
            <button class="btn btn-outline-primary">
                <i class="fas fa-download me-2"></i>Exporter
            </button>
            <button class="btn btn-primary">
                <i class="fas fa-plus me-2"></i>Nouveau
            </button>
        </div>
    </div>

    <div class="row g-4 mb-5">
        <div class="col-xl-3 col-md-6">
            <div class="stat-card bg-gradient" style="background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);">
                <div class="d-flex align-items-start justify-content-between">
                    <div class="text-white">
                        <p class="stat-label">Utilisateurs</p>
                        <h3 class="stat-number">{{ utilisateurs|default(0) }}</h3>
                        <span class="trend-badge bg-white bg-opacity-25">
                            <i class="fas fa-arrow-up me-1"></i>+12% ce mois
                        </span>
                    </div>
                    <div class="stat-icon bg-white bg-opacity-20">
                        <i class="fas fa-users text-white"></i>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-xl-3 col-md-6">
            <div class="stat-card bg-gradient" style="background: linear-gradient(135deg, #06b6d4 0%, #0891b2 100%);">
                <div class="d-flex align-items-start justify-content-between">
                    <div class="text-white">
                        <p class="stat-label">Événements</p>
                        <h3 class="stat-number">{{ evenements|default(0) }}</h3>
                        <span class="trend-badge bg-white bg-opacity-25">
                            <i class="fas fa-calendar me-1"></i>Actifs
                        </span>
                    </div>
                    <div class="stat-icon bg-white bg-opacity-20">
                        <i class="fas fa-calendar-alt text-white"></i>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-xl-3 col-md-6">
            <div class="stat-card bg-gradient" style="background: linear-gradient(135deg, #f97316 0%, #ea580c 100%);">
                <div class="d-flex align-items-start justify-content-between">
                    <div class="text-white">
                        <p class="stat-label">Filières</p>
                        <h3 class="stat-number">{{ filieres|default(0) }}</h3>
                        <span class="trend-badge bg-white bg-opacity-25">
                            <i class="fas fa-book me-1"></i>Programmes
                        </span>
                    </div>
                    <div class="stat-icon bg-white bg-opacity-20">
                        <i class="fas fa-book text-white"></i>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-xl-3 col-md-6">
            <div class="stat-card bg-gradient" style="background: linear-gradient(135deg, #ef4444 0%, #dc2626 100%);">
                <div class="d-flex align-items-start justify-content-between">
                    <div class="text-white">
                        <p class="stat-label">Établissements</p>
                        <h3 class="stat-number">{{ etablissements|default(0) }}</h3>
                        <span class="trend-badge bg-white bg-opacity-25">
                            <i class="fas fa-building me-1"></i>Partenaires
                        </span>
                    </div>
                    <div class="stat-icon bg-white bg-opacity-20">
                        <i class="fas fa-university text-white"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="row g-4 mb-5">
        <div class="col-xl-8">
            <div class="card chart-card">
                <div class="card-header d-flex justify-content-between align-items-center">
                    <div>
                        <h5 class="mb-0 fw-bold"><i class="fas fa-chart-area me-2"></i>Activité mensuelle</h5>
                        <small class="opacity-75">Évolution des inscriptions et événements</small>
                    </div>
                    <div class="btn-group" role="group">
                        <button class="btn btn-light btn-sm active">Mois</button>
                        <button class="btn btn-light btn-sm">Trimestre</button>
                        <button class="btn btn-light btn-sm">Année</button>
                    </div>
                </div>
                <div class="card-body">
                    <div style="height: 380px;">
                        <canvas id="mainChart"></canvas>
                    </div>
                </div>
            </div>
        </div>
        
        <div class="col-xl-4">
            <div class="card chart-card">
                <div class="card-header">
                    <h5 class="mb-0 fw-bold"><i class="fas fa-chart-pie me-2"></i>Répartition</h5>
                </div>
                <div class="card-body">
                    <div style="height: 300px;">
                        <canvas id="pieChart"></canvas>
                    </div>
                </div>
            </div>
        </div>
    </div>

        <div class="row g-4">
            <div class="col-xl-6">
                <div class="card chart-card">
                    <div class="card-header">
                        <h5 class="mb-0 fw-bold"><i class="fas fa-building me-2"></i>Derniers établissements</h5>
                    </div>
                    <div class="card-body">
                        <div class="list-group list-group-flush">
                            {% if derniersEtablissements|length > 0 %}
                                {% for etablissement in derniersEtablissements %}
                                    <div class="list-group-item px-0 d-flex align-items-center">
                                        <div class="me-3">
                                            {% if etablissement.imageUrl %}
                                                <img src="{{ asset(etablissement.imageUrl) }}" alt="{{ etablissement.nom }}" class="rounded" style="width: 50px; height: 50px; object-fit: cover;">
                                            {% else %}
                                                <div class="stat-icon" style="background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); width: 50px; height: 50px;">
                                                    <i class="fas fa-school text-white" style="font-size: 20px;"></i>
                                                </div>
                                            {% endif %}
                                        </div>
                                        <div class="flex-grow-1">
                                            <h6 class="mb-0 fw-bold">{{ etablissement.nom }}</h6>
                                            <small class="text-muted">{{ etablissement.ville }}</small>
                                        </div>
                                        <span class="badge bg-success rounded-pill">Actif</span>
                                    </div>
                                {% endfor %}
                            {% else %}
                                <div class="text-center py-4 text-muted">
                                    <i class="fas fa-building fa-3x mb-3"></i>
                                    <p>Aucun établissement trouvé</p>
                                </div>
                            {% endif %}
                        </div>
                    </div>
                </div>
            </div>
            
            <div class="col-xl-6">
                <div class="card chart-card">
                    <div class="card-header">
                        <h5 class="mb-0 fw-bold"><i class="fas fa-calendar-check me-2"></i>Prochains événements</h5>
                    </div>
                    <div class="card-body">
                        <div class="list-group list-group-flush">
                            {% if prochainsEvenements|length > 0 %}
                                {% for evenement in prochainsEvenements %}
                                    <div class="list-group-item px-0">
                                        <div class="d-flex">
                                            <div class="me-3 text-center">
                                                {% if evenement.imageUrl %}
                                                    <img src="{{ asset(evenement.imageUrl) }}" alt="{{ evenement.titre }}" class="rounded" style="width: 50px; height: 50px; object-fit: cover;">
                                                {% else %}
                                                    <div class="stat-icon" style="background: #ef4444; width: 50px; height: 50px;">
                                                        <span class="text-white fw-bold">{{ evenement.dateDebut|date('d') }}</span>
                                                    </div>
                                                {% endif %}
                                                <small class="text-muted">{{ evenement.dateDebut|date('M') }}</small>
                                            </div>
                                            <div class="flex-grow-1">
                                                <h6 class="mb-1 fw-bold">{{ evenement.titre }}</h6>
                                                <small class="text-muted"><i class="fas fa-map-marker-alt me-1"></i>{{ evenement.lieu }}</small>
                                            </div>
                                        </div>
                                    </div>
                                {% endfor %}
                            {% else %}
                                <div class="text-center py-4 text-muted">
                                    <i class="fas fa-calendar fa-3x mb-3"></i>
                                    <p>Aucun événement à venir</p>
                                </div>
                            {% endif %}
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

{% endblock %}

{% block javascripts %}
    {{ parent() }}
    
    <script>
        function initMainChart() {
            const ctx = document.getElementById('mainChart').getContext('2d');
            new Chart(ctx, {
                type: 'line',
                data: {
                    labels: ['Jan', 'Fév', 'Mar', 'Avr', 'Mai', 'Juin', 'Juil'],
                    datasets: [
                        {
                            label: 'Utilisateurs',
                            data: [45, 58, 72, 88, 95, {{ utilisateurs|default(80) }}, {{ (utilisateurs|default(80)) + 10 }}],
                            borderColor: '#667eea',
                            backgroundColor: 'rgba(102, 126, 234, 0.1)',
                            borderWidth: 4,
                            tension: 0.4,
                            pointRadius: 6,
                            pointBackgroundColor: '#667eea',
                            pointBorderWidth: 3,
                            pointBorderColor: '#fff',
                            fill: true
                        },
                        {
                            label: 'Événements',
                            data: [12, 18, 22, 25, 28, {{ evenements|default(25) }}, {{ (evenements|default(25)) + 5 }}],
                            borderColor: '#06b6d4',
                            backgroundColor: 'rgba(6, 182, 212, 0.1)',
                            borderWidth: 4,
                            tension: 0.4,
                            pointRadius: 6,
                            pointBackgroundColor: '#06b6d4',
                            pointBorderWidth: 3,
                            pointBorderColor: '#fff',
                            fill: true
                        }
                    ]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: {
                        legend: {
                            position: 'top',
                            labels: {
                                padding: 20,
                                font: { size: 14, weight: '600' },
                                usePointStyle: true,
                                pointStyle: 'circle'
                            }
                        }
                    },
                    scales: {
                        x: {
                            grid: { color: 'rgba(0,0,0,0.05)' },
                            ticks: { font: { size: 13, weight: '500' } }
                        },
                        y: {
                            grid: { color: 'rgba(0,0,0,0.05)' },
                            ticks: { font: { size: 13, weight: '500' } }
                        }
                    }
                }
            });
        }

        function initPieChart() {
            const ctx = document.getElementById('pieChart').getContext('2d');
            new Chart(ctx, {
                type: 'doughnut',
                data: {
                    labels: ['Utilisateurs', 'Établissements', 'Filières', 'Événements'],
                    datasets: [{
                        data: [{{ utilisateurs|default(0) }}, {{ etablissements|default(0) }}, {{ filieres|default(0) }}, {{ evenements|default(0) }}],
                        backgroundColor: [
                            '#667eea',
                            '#06b6d4',
                            '#f97316',
                            '#ef4444'
                        ],
                        borderWidth: 0,
                        hoverOffset: 10
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: {
                        legend: {
                            position: 'bottom',
                            labels: {
                                padding: 20,
                                font: { size: 13, weight: '600' },
                                usePointStyle: true
                            }
                        }
                    },
                    cutout: '65%'
                }
            });
        }

        window.addEventListener('load', function() {
            initMainChart();
            initPieChart();
        });
    </script>
{% endblock %}