{# templates/base.html.twig #}
<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{% block title %}SchoolManager{% endblock %}</title>
   
    <!-- CSS -->
    <link rel="stylesheet" href="{{ asset('admin/assets/css/theme.css') }}">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/remixicon/fonts/remixicon.css" rel="stylesheet">
   
    {% block stylesheets %}{% endblock %}
   
    <style>
        /* ===== NAVBAR ===== */
        .navbar {
            height: 70px;
            position: fixed;
            top: 0;
            left: 0;
            right: 0;
            z-index: 1050;
        }
        
        /* ===== SIDEBAR ===== */
        .sidebar {
            position: fixed;
            top: 70px;
            left: 0;
            width: 250px;
            height: calc(100vh - 70px);
            background-color: #1e1e2d;
            overflow-y: auto;
            z-index: 1040;
        }

        /* ===== CONTENU PRINCIPAL - CORRECTION DU DÉPLACEMENT ===== */
        .main-content {
            margin-left: 250px;
            margin-top: 70px;
            padding: 35px;
            min-height: calc(100vh - 70px);
            background-color: #f8f9fa;
            width: calc(100% - 250px);
        }

        /* Pour éviter les chevauchements */
        .main-content .container-fluid {
            max-width: 100%;
        }
    </style>
</head>
<body>

    <!-- ✅ NAVBAR FIXE -->
    {% include 'admin/partials/topbar-second.html.twig' %}

    <!-- ===== LAYOUT ===== -->
    <div class="d-flex">

        <!-- SIDEBAR -->
        {% include 'admin/partials/sidebar-collapse.html.twig' %}   <!-- Nom que tu utilises -->

        <!-- CONTENU PRINCIPAL -->
        <div class="main-content flex-grow-1">
            {% block content %}
                <!-- Le contenu du dashboard apparaîtra ici -->
            {% endblock %}
        </div>

    </div>

    <!-- FOOTER -->
    {% include 'admin/partials/footer.html.twig' %}

    <!-- JS -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    {% block javascripts %}{% endblock %}

</body>
</html>