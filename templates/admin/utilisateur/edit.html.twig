{% extends 'admin/base.html.twig' %}

{% block title %}Modifier Utilisateur - SchoolPrepar{% endblock %}

{% block admin_content %}
<div class="container-fluid">

    <div class="admin-page-header">
        <div class="d-flex align-items-center">
            <a href="{{ path('admin_utilisateur') }}" class="btn btn-outline-secondary me-3">
                <i class="fas fa-arrow-left"></i>
            </a>
            <div>
                <h1><i class="fas fa-user"></i>Modifier l'Utilisateur</h1>
                <p>Modifiez les informations de {{ utilisateur.prenom }} {{ utilisateur.nom }}</p>
            </div>
        </div>
    </div>

    <div class="row">
        <div class="col-lg-8">
            <div class="admin-card">
                <div class="admin-card-header">
                    <h5><i class="fas fa-edit me-2"></i>Modifier les informations</h5>
                </div>
                <div class="card-body">
                    {{ form_start(form, {'attr': {'novalidate': 'novalidate'}}) }}

                    <div class="row">
                        <div class="col-md-6 mb-4">
                            {{ form_label(form.nom, null, {'label_attr': {'class': 'form-label fw-semibold'}}) }}
                            {{ form_widget(form.nom, {'attr': {'class': 'form-control'}}) }}
                            {{ form_errors(form.nom) }}
                        </div>
                        <div class="col-md-6 mb-4">
                            {{ form_label(form.prenom, null, {'label_attr': {'class': 'form-label fw-semibold'}}) }}
                            {{ form_widget(form.prenom, {'attr': {'class': 'form-control'}}) }}
                            {{ form_errors(form.prenom) }}
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-md-12 mb-4">
                            {{ form_label(form.email, null, {'label_attr': {'class': 'form-label fw-semibold'}}) }}
                            {{ form_widget(form.email, {'attr': {'class': 'form-control'}}) }}
                            {{ form_errors(form.email) }}
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-md-6 mb-4">
                            {{ form_label(form.filiere, null, {'label_attr': {'class': 'form-label fw-semibold'}}) }}
                            {{ form_widget(form.filiere, {'attr': {'class': 'form-select'}}) }}
                            {{ form_errors(form.filiere) }}
                        </div>
                        <div class="col-md-6 mb-4">
                            {{ form_label(form.roles, null, {'label_attr': {'class': 'form-label fw-semibold'}}) }}
                            {{ form_widget(form.roles) }}
                            {{ form_errors(form.roles) }}
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-md-12 mb-4">
                            {{ form_label(form.evenements, null, {'label_attr': {'class': 'form-label fw-semibold'}}) }}
                            {{ form_widget(form.evenements) }}
                            {{ form_errors(form.evenements) }}
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-md-12 mb-4">
                            {{ form_label(form.imageFile, null, {'label_attr': {'class': 'form-label fw-semibold'}}) }}
                            {% if utilisateur.imageUrl %}
                                <div class="mb-3">
                                    <img src="{{ utilisateur.imageUrl }}" alt="{{ utilisateur.prenom }} {{ utilisateur.nom }}" class="img-thumbnail rounded-circle" style="max-height: 100px; width: 100px; object-fit: cover;">
                                </div>
                                <small class="text-muted d-block mb-2">Photo actuelle - téléchargez une nouvelle image pour la remplacer</small>
                            {% endif %}
                            {{ form_widget(form.imageFile, {'attr': {'class': 'form-control'}}) }}
                            {{ form_errors(form.imageFile) }}
                        </div>
                    </div>

                    <hr class="my-4">

                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-admin-warning">
                            <i class="fas fa-save me-2"></i>Enregistrer les modifications
                        </button>
                        <a href="{{ path('admin_utilisateur') }}" class="btn btn-outline-secondary">
                            <i class="fas fa-times me-2"></i>Annuler
                        </a>
                    </div>

                    {{ form_end(form) }}
                </div>
            </div>
        </div>

        <div class="col-lg-4">
            <div class="admin-card mb-4">
                <div class="admin-card-header">
                    <h5><i class="fas fa-info-circle me-2"></i>Informations</h5>
                </div>
                <div class="card-body">
                    <ul class="list-unstyled mb-0">
                        <li class="mb-3">
                            <strong>ID:</strong> #{{ utilisateur.id }}
                        </li>
                        <li class="mb-3">
                            <strong>Nom complet:</strong> {{ utilisateur.prenom }} {{ utilisateur.nom }}
                        </li>
                        <li class="mb-3">
                            <strong>Email:</strong> {{ utilisateur.email }}
                        </li>
                        <li>
                            <strong>Événements:</strong> {{ utilisateur.evenements|length }}
                        </li>
                    </ul>
                </div>
            </div>

            <div class="admin-card">
                <div class="admin-card-header">
                    <h5><i class="fas fa-lightbulb me-2"></i>Astuces</h5>
                </div>
                <div class="card-body">
                    <ul class="list-unstyled mb-0">
                        <li class="mb-3">
                            <i class="fas fa-check-circle text-success me-2"></i>
                            Vérifiez toutes les informations avant de sauvegarder
                        </li>
                        <li class="mb-3">
                            <i class="fas fa-check-circle text-success me-2"></i>
                            Une nouvelle photo remplacera l'ancienne
                        </li>
                        <li>
                            <i class="fas fa-check-circle text-success me-2"></i>
                            Les modifications sont immédiatement enregistrées
                        </li>
                    </ul>
                </div>
            </div>
        </div>
    </div>

</div>
{% endblock %}