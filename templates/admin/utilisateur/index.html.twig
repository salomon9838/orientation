{% extends 'admin/base.html.twig' %}

{% block title %}Gestion des Utilisateurs - SchoolPrepar{% endblock %}

{% block admin_content %}
<div class="container-fluid">

    <div class="admin-page-header">
        <h1><i class="fas fa-users"></i>Gestion des Utilisateurs</h1>
        <p>Gérez tous les utilisateurs de la plateforme</p>
    </div>

    <div class="d-flex justify-content-between align-items-center mb-4">
        <div class="d-flex gap-2">
            <button class="btn btn-outline-secondary">
                <i class="fas fa-filter me-2"></i>Filtrer
            </button>
            <button class="btn btn-outline-secondary">
                <i class="fas fa-download me-2"></i>Exporter
            </button>
        </div>
    </div>

    <div class="admin-card">
        <div class="admin-card-header d-flex justify-content-between align-items-center">
            <h5><i class="fas fa-list me-2"></i>Liste des utilisateurs</h5>
            <span class="badge bg-primary">{{ utilisateurs|length }} utilisateur(s)</span>
        </div>
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table admin-table mb-0">
                    <thead>
                        <tr>
                            <th>#</th>
                            <th>Utilisateur</th>
                            <th>Email</th>
                            <th>Rôles</th>
                            <th>Filière</th>
                            <th class="text-center">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                    {% for utilisateur in utilisateurs %}
                        <tr>
                            <td><span class="fw-semibold">#{{ utilisateur.id }}</span></td>
                            <td>
                                <div class="d-flex align-items-center">
                                    {% if utilisateur.imageUrl %}
                                        <img src="{{ utilisateur.imageUrl }}" alt="{{ utilisateur.prenom }} {{ utilisateur.nom }}" class="rounded-circle me-3" style="width: 40px; height: 40px; object-fit: cover;">
                                    {% else %}
                                        <div class="rounded-circle me-3 d-flex align-items-center justify-content-center" style="width: 40px; height: 40px; background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);">
                                            <span class="text-white fw-bold" style="font-size: 14px;">{{ utilisateur.prenom|first|upper }}{{ utilisateur.nom|first|upper }}</span>
                                        </div>
                                    {% endif %}
                                    <div>
                                        <strong class="text-dark">{{ utilisateur.prenom }} {{ utilisateur.nom }}</strong>
                                    </div>
                                </div>
                            </td>
                            <td>
                                <a href="mailto:{{ utilisateur.email }}" class="text-decoration-none text-dark">{{ utilisateur.email }}</a>
                            </td>
                            <td>
                                {% for role in utilisateur.roles %}
                                    <span class="badge badge-status {{ role == 'ROLE_ADMIN' ? 'bg-danger' : 'bg-info' }}">{{ role }}</span>
                                {% endfor %}
                            </td>
                            <td>
                                {% if utilisateur.filiere %}
                                    <i class="fas fa-graduation-cap text-muted me-2"></i>{{ utilisateur.filiere.nom }}
                                {% else %}
                                    <span class="text-muted">-</span>
                                {% endif %}
                            </td>
                            <td class="text-center">
                                <a href="{{ path('admin_utilisateur_show', {'id': utilisateur.id}) }}" class="btn-action btn-view">
                                    <i class="fas fa-eye"></i>
                                </a>
                                <form method="POST" action="{{ path('admin_utilisateur_delete', {'id': utilisateur.id}) }}" class="d-inline" onsubmit="return confirm('Voulez-vous vraiment supprimer cet utilisateur ? Cette action est irréversible.');">
                                    <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ utilisateur.id) }}">
                                    <button type="submit" class="btn-action btn-delete">
                                        <i class="fas fa-trash"></i>
                                    </button>
                                </form>
                            </td>
                        </tr>
                    {% else %}
                        <tr>
                            <td colspan="6" class="text-center py-5">
                                <div class="text-muted">
                                    <i class="fas fa-users fa-3x mb-3 opacity-25"></i>
                                    <h5 class="fw-semibold mb-2">Aucun utilisateur trouvé</h5>
                                </div>
                            </td>
                        </tr>
                    {% endfor %}
                    </tbody>
                </table>
            </div>
        </div>
    </div>

</div>
{% endblock %}