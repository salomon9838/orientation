{% extends 'admin/base.html.twig' %}

{% block title %}Détails Utilisateur - SchoolPrepar{% endblock %}

{% block admin_content %}
<div class="container-fluid">

    <div class="admin-page-header">
        <div class="d-flex align-items-center">
            <a href="{{ path('admin_utilisateur') }}" class="btn btn-outline-secondary me-3">
                <i class="fas fa-arrow-left"></i>
            </a>
            <div>
                <h1><i class="fas fa-user"></i>Détails de l'Utilisateur</h1>
                <p>Consultez et gérez les informations de {{ utilisateur.prenom }} {{ utilisateur.nom }}</p>
            </div>
        </div>
    </div>

    <div class="row">
        <div class="col-lg-4 mb-4">
            <div class="admin-card">
                <div class="admin-card-header">
                    <h5><i class="fas fa-image me-2"></i>Photo de profil</h5>
                </div>
                <div class="card-body text-center">
                    {% if utilisateur.imageUrl %}
                        <img src="{{ utilisateur.imageUrl }}" alt="{{ utilisateur.prenom }} {{ utilisateur.nom }}" class="img-fluid rounded-circle mb-3" style="max-height: 200px; width: 200px; object-fit: cover;">
                    {% else %}
                        <div class="d-flex align-items-center justify-content-center bg-light rounded-circle mb-3" style="height: 200px; width: 200px;">
                            <i class="fas fa-user fa-5x text-muted opacity-25"></i>
                        </div>
                        <p class="text-muted mb-0">Aucune photo de profil</p>
                    {% endif %}
                </div>
            </div>
            
            <div class="admin-card">
                <div class="admin-card-header">
                    <h5><i class="fas fa-chart-bar me-2"></i>Informations rapides</h5>
                </div>
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center mb-3">
                        <span class="text-muted"><i class="fas fa-user-tag me-2"></i>Rôles</span>
                        <div>
                            {% for role in utilisateur.roles %}
                                <span class="badge badge-status {{ role == 'ROLE_ADMIN' ? 'bg-danger' : 'bg-info' }}">{{ role }}</span>
                            {% endfor %}
                        </div>
                    </div>
                    <div class="d-flex justify-content-between align-items-center">
                        <span class="text-muted"><i class="fas fa-calendar me-2"></i>Inscrit</span>
                        <span class="fw-bold">{{ utilisateur.createdAt ? utilisateur.createdAt|date('d/m/Y') : '-' }}</span>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-lg-8">
            <div class="admin-card mb-4">
                <div class="admin-card-header d-flex justify-content-between align-items-center">
                    <h5><i class="fas fa-info-circle me-2"></i>Informations générales</h5>
                </div>
                <div class="card-body">
                    <div class="row">
                        <div class="col-md-6 mb-4">
                            <label class="form-label fw-semibold text-muted">Prénom</label>
                            <h5 class="mb-0">{{ utilisateur.prenom }}</h5>
                        </div>
                        <div class="col-md-6 mb-4">
                            <label class="form-label fw-semibold text-muted">Nom</label>
                            <h5 class="mb-0">{{ utilisateur.nom }}</h5>
                        </div>
                        <div class="col-md-12 mb-4">
                            <label class="form-label fw-semibold text-muted">Email</label>
                            <p class="mb-0"><a href="mailto:{{ utilisateur.email }}" class="text-decoration-none text-dark">{{ utilisateur.email }}</a></p>
                        </div>
                        <div class="col-md-12 mb-4">
                            <label class="form-label fw-semibold text-muted">Filière</label>
                            <h5 class="mb-0">
                                {% if utilisateur.filiere %}
                                    <i class="fas fa-graduation-cap text-muted me-2"></i>{{ utilisateur.filiere.nom }}
                                {% else %}
                                    <span class="text-muted">-</span>
                                {% endif %}
                            </h5>
                        </div>
                    </div>
                </div>
            </div>

            <div class="admin-card">
                <div class="admin-card-header">
                    <h5><i class="fas fa-cog me-2"></i>Actions</h5>
                </div>
                <div class="card-body">
                    <div class="d-flex flex-wrap gap-2">
                        <a href="{{ path('admin_utilisateur_edit', {'id': utilisateur.id}) }}" class="btn btn-admin-warning">
                            <i class="fas fa-edit me-2"></i>Modifier
                        </a>
                        <a href="{{ path('admin_utilisateur') }}" class="btn btn-outline-secondary">
                            <i class="fas fa-arrow-left me-2"></i>Retour à la liste
                        </a>
                        <form method="POST" action="{{ path('admin_utilisateur_delete', {'id': utilisateur.id}) }}" class="ms-auto" onsubmit="return confirm('Voulez-vous vraiment supprimer cet utilisateur ? Cette action est irréversible.');">
                            <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ utilisateur.id) }}">
                            <button type="submit" class="btn btn-admin-danger">
                                <i class="fas fa-trash me-2"></i>Supprimer
                            </button>
                        </form>
                    </div>
                </div>
            </div>

            {% if utilisateur.evenements|length > 0 %}
            <div class="admin-card mt-4">
                <div class="admin-card-header">
                    <h5><i class="fas fa-calendar-check me-2"></i>Événements inscrits ({{ utilisateur.evenements|length }})</h5>
                </div>
                <div class="card-body p-0">
                    <div class="table-responsive">
                        <table class="table admin-table mb-0">
                            <thead>
                                <tr>
                                    <th>Titre</th>
                                    <th>Lieu</th>
                                    <th>Date de début</th>
                                    <th>Date de fin</th>
                                </tr>
                            </thead>
                            <tbody>
                            {% for evenement in utilisateur.evenements %}
                                <tr>
                                    <td><strong>{{ evenement.titre }}</strong></td>
                                    <td>{{ evenement.lieu }}</td>
                                    <td>{{ evenement.dateDebut|date('d/m/Y H:i') }}</td>
                                    <td>{{ evenement.dateFin|date('d/m/Y H:i') }}</td>
                                </tr>
                            {% endfor %}
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
            {% endif %}
        </div>
    </div>

</div>
{% endblock %}