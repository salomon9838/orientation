{% extends 'admin/base.html.twig' %}

{% block title %}Détails Événement - SchoolPrepar{% endblock %}

{% block admin_content %}
<div class="container-fluid">

    <div class="admin-page-header">
        <div class="d-flex align-items-center">
            <a href="{{ path('admin_evenement') }}" class="btn btn-outline-secondary me-3">
                <i class="fas fa-arrow-left"></i>
            </a>
            <div>
                <h1><i class="fas fa-calendar-alt"></i>Détails de l'Événement</h1>
                <p>Consultez et gérez les informations de {{ evenement.titre }}</p>
            </div>
        </div>
    </div>

    <div class="row">
        <div class="col-lg-4 mb-4">
            <div class="admin-card">
                <div class="admin-card-header">
                    <h5><i class="fas fa-image me-2"></i>Image</h5>
                </div>
                <div class="card-body text-center">
                    {% if evenement.imageUrl %}
                        <img src="{{ evenement.imageUrl }}" alt="{{ evenement.titre }}" class="img-fluid rounded mb-3" style="max-height: 250px; object-fit: cover;">
                    {% else %}
                        <div class="d-flex align-items-center justify-content-center bg-light rounded mb-3" style="height: 250px;">
                            <i class="fas fa-calendar-alt fa-5x text-muted opacity-25"></i>
                        </div>
                        <p class="text-muted mb-0">Aucune image</p>
                    {% endif %}
                </div>
            </div>
            
            <div class="admin-card">
                <div class="admin-card-header">
                    <h5><i class="fas fa-info-circle me-2"></i>Informations rapides</h5>
                </div>
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center mb-3">
                        <span class="text-muted"><i class="fas fa-users me-2"></i>Participants</span>
                        <span class="fw-bold">{{ evenement.utilisateurs|length }}</span>
                    </div>
                    <div class="d-flex justify-content-between align-items-center">
                        <span class="text-muted"><i class="fas fa-university me-2"></i>Établissement</span>
                        <span class="fw-bold">{{ evenement.etablissement ? evenement.etablissement.nom : '-' }}</span>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-lg-8">
            <div class="admin-card mb-4">
                <div class="admin-card-header d-flex justify-content-between align-items-center">
                    <h5><i class="fas fa-info-circle me-2"></i>Informations générales</h5>
                </div>
                <div class="card-body">
                    <div class="row">
                        <div class="col-md-12 mb-4">
                            <label class="form-label fw-semibold text-muted">Titre</label>
                            <h5 class="mb-0">{{ evenement.titre }}</h5>
                        </div>
                        <div class="col-md-12 mb-4">
                            <label class="form-label fw-semibold text-muted">Description</label>
                            <p class="mb-0">{{ evenement.description }}</p>
                        </div>
                        <div class="col-md-6 mb-4">
                            <label class="form-label fw-semibold text-muted">Date de début</label>
                            <h5 class="mb-0">{{ evenement.dateDebut|date('d/m/Y H:i') }}</h5>
                        </div>
                        <div class="col-md-6 mb-4">
                            <label class="form-label fw-semibold text-muted">Date de fin</label>
                            <h5 class="mb-0">{{ evenement.dateFin|date('d/m/Y H:i') }}</h5>
                        </div>
                        <div class="col-md-12 mb-4">
                            <label class="form-label fw-semibold text-muted">Lieu</label>
                            <h5 class="mb-0"><i class="fas fa-map-marker-alt text-muted me-2"></i>{{ evenement.lieu }}</h5>
                        </div>
                        <div class="col-md-12">
                            <label class="form-label fw-semibold text-muted">Établissement</label>
                            <h5 class="mb-0">
                                {% if evenement.etablissement %}
                                    <i class="fas fa-university text-muted me-2"></i>{{ evenement.etablissement.nom }}
                                {% else %}
                                    <span class="text-muted">-</span>
                                {% endif %}
                            </h5>
                        </div>
                    </div>
                </div>
            </div>

            <div class="admin-card">
                <div class="admin-card-header">
                    <h5><i class="fas fa-cog me-2"></i>Actions</h5>
                </div>
                <div class="card-body">
                    <div class="d-flex flex-wrap gap-2">
                        <a href="{{ path('admin_evenement_edit', {'id': evenement.id}) }}" class="btn btn-admin-warning">
                            <i class="fas fa-edit me-2"></i>Modifier
                        </a>
                        <a href="{{ path('admin_evenement') }}" class="btn btn-outline-secondary">
                            <i class="fas fa-arrow-left me-2"></i>Retour à la liste
                        </a>
                        <form method="POST" action="{{ path('admin_evenement_delete', {'id': evenement.id}) }}" class="ms-auto" onsubmit="return confirm('Voulez-vous vraiment supprimer cet événement ? Cette action est irréversible.');">
                            <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ evenement.id) }}">
                            <button type="submit" class="btn btn-admin-danger">
                                <i class="fas fa-trash me-2"></i>Supprimer
                            </button>
                        </form>
                    </div>
                </div>
            </div>

            {% if evenement.utilisateurs|length > 0 %}
            <div class="admin-card mt-4">
                <div class="admin-card-header">
                    <h5><i class="fas fa-users me-2"></i>Participants ({{ evenement.utilisateurs|length }})</h5>
                </div>
                <div class="card-body p-0">
                    <div class="table-responsive">
                        <table class="table admin-table mb-0">
                            <thead>
                                <tr>
                                    <th>Nom</th>
                                    <th>Prénom</th>
                                    <th>Email</th>
                                </tr>
                            </thead>
                            <tbody>
                            {% for utilisateur in evenement.utilisateurs %}
                                <tr>
                                    <td><strong>{{ utilisateur.nom }}</strong></td>
                                    <td>{{ utilisateur.prenom }}</td>
                                    <td>{{ utilisateur.email }}</td>
                                </tr>
                            {% endfor %}
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
            {% endif %}
        </div>
    </div>

</div>
{% endblock %}