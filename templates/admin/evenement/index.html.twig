{% extends 'admin/base.html.twig' %}

{% block title %}Gestion des Événements - SchoolPrepar{% endblock %}

{% block admin_content %}
<div class="container-fluid">

    <div class="admin-page-header">
        <h1><i class="fas fa-calendar-alt"></i>Gestion des Événements</h1>
        <p>Gérez tous les événements de la plateforme</p>
    </div>

    <div class="d-flex justify-content-between align-items-center mb-4">
        <div class="d-flex gap-2">
            <button class="btn btn-outline-secondary">
                <i class="fas fa-filter me-2"></i>Filtrer
            </button>
            <button class="btn btn-outline-secondary">
                <i class="fas fa-download me-2"></i>Exporter
            </button>
        </div>
        <a href="{{ path('admin_evenement_new') }}" class="btn btn-admin-primary">
            <i class="fas fa-plus me-2"></i>Nouvel Événement
        </a>
    </div>

    <div class="admin-card">
        <div class="admin-card-header d-flex justify-content-between align-items-center">
            <h5><i class="fas fa-list me-2"></i>Liste des événements</h5>
            <span class="badge bg-primary">{{ evenements|length }} événement(s)</span>
        </div>
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table admin-table mb-0">
                    <thead>
                        <tr>
                            <th>#</th>
                            <th>Événement</th>
                            <th>Dates</th>
                            <th>Lieu</th>
                            <th>Établissement</th>
                            <th class="text-center">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                    {% for evenement in evenements %}
                        <tr>
                            <td><span class="fw-semibold">#{{ evenement.id }}</span></td>
                            <td>
                                <div class="d-flex align-items-center">
                                    {% if evenement.imageUrl %}
                                        <img src="{{ evenement.imageUrl }}" alt="{{ evenement.titre }}" class="rounded me-3" style="width: 60px; height: 45px; object-fit: cover;">
                                    {% else %}
                                        <div class="rounded me-3 d-flex align-items-center justify-content-center" style="width: 60px; height: 45px; background: linear-gradient(135deg, #ef4444 0%, #dc2626 100%);">
                                            <i class="fas fa-calendar-alt text-white" style="font-size: 18px;"></i>
                                        </div>
                                    {% endif %}
                                    <strong class="text-dark">{{ evenement.titre }}</strong>
                                </div>
                            </td>
                            <td>
                                <small class="text-muted">Du</small><br>
                                {{ evenement.dateDebut|date('d/m/Y H:i') }}<br>
                                <small class="text-muted">Au</small><br>
                                {{ evenement.dateFin|date('d/m/Y H:i') }}
                            </td>
                            <td>
                                <i class="fas fa-map-marker-alt text-muted me-2"></i>{{ evenement.lieu }}
                            </td>
                            <td>
                                {% if evenement.etablissement %}
                                    <i class="fas fa-university text-muted me-2"></i>{{ evenement.etablissement.nom }}
                                {% else %}
                                    <span class="text-muted">-</span>
                                {% endif %}
                            </td>
                            <td class="text-center">
                                <a href="{{ path('admin_evenement_show', {'id': evenement.id}) }}" class="btn-action btn-view">
                                    <i class="fas fa-eye"></i>
                                </a>
                                <a href="{{ path('admin_evenement_edit', {'id': evenement.id}) }}" class="btn-action btn-edit">
                                    <i class="fas fa-edit"></i>
                                </a>
                                <form method="POST" action="{{ path('admin_evenement_delete', {'id': evenement.id}) }}" class="d-inline" onsubmit="return confirm('Voulez-vous vraiment supprimer cet événement ? Cette action est irréversible.');">
                                    <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ evenement.id) }}">
                                    <button type="submit" class="btn-action btn-delete">
                                        <i class="fas fa-trash"></i>
                                    </button>
                                </form>
                            </td>
                        </tr>
                    {% else %}
                        <tr>
                            <td colspan="6" class="text-center py-5">
                                <div class="text-muted">
                                    <i class="fas fa-calendar-alt fa-3x mb-3 opacity-25"></i>
                                    <h5 class="fw-semibold mb-2">Aucun événement trouvé</h5>
                                    <p class="mb-3">Commencez par ajouter votre premier événement</p>
                                    <a href="{{ path('admin_evenement_new') }}" class="btn btn-admin-primary">
                                        <i class="fas fa-plus me-2"></i>Ajouter un événement
                                    </a>
                                </div>
                            </td>
                        </tr>
                    {% endfor %}
                    </tbody>
                </table>
            </div>
        </div>
    </div>

</div>
{% endblock %}