{% extends 'base.html.twig' %}

{% block title %}Etablissement index{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    
    <!-- Bootstrap 5 -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
{% endblock %}

{% block body %}
<div class="container py-5">
    
    <div class="card shadow-sm border-0">
        <div class="card-body">

            <h1 class="text-center fw-bold mb-4">Listes des Etablissements</h1>

            <div class="table-responsive">
                <table class="table table-striped table-hover align-middle text-center">
                    <thead class="table-primary">
                        <tr>
                            <th>Id</th>
                            <th>Nom</th>
                            <th>Adresse</th>
                            <th>Ville</th>
                            <th>Telephone</th>
                            <th>Email</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                    {% for etablissement in etablissements %}
                        <tr>
                            <td>{{ etablissement.id }}</td>
                            <td class="fw-semibold">{{ etablissement.nom }}</td>
                            <td>{{ etablissement.adresse }}</td>
                            <td>{{ etablissement.ville }}</td>
                            <td>{{ etablissement.telephone }}</td>
                            <td>{{ etablissement.email }}</td>
                            <td>
                                <a href="{{ path('app_etablissements_show', {'id': etablissement.id}) }}" class="btn btn-sm btn-outline-primary me-1">
                                    Voir
                                </a>
                                <a href="{{ path('app_etablissements_edit', {'id': etablissement.id}) }}" class="btn btn-sm btn-outline-warning">
                                    Modifier
                                </a>
                            </td>
                        </tr>
                    {% else %}
                        <tr>
                            <td colspan="7" class="text-muted">Aucun enregistrement trouvé</td>
                        </tr>
                    {% endfor %}
                    </tbody>
                </table>
            </div>

            <div class="d-flex justify-content-end mt-3">
                <a href="{{ path('app_etablissements_new') }}" class="btn btn-success">
                    + Créer un établissement
                </a>
            </div>

        </div>
    </div>

</div>
{% endblock %}