{% extends 'base.html.twig' %}

{% block title %}{{ etablissement.nom }} - Établissement{% endblock %}

{% block body %}

<div class="container mt-4">

    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-bold text-primary">🏫 {{ etablissement.nom }}</h2>
        <div>
            <a href="{{ path('app_etablissements_index') }}" class="btn btn-secondary btn-sm">⬅ Retour</a>
            <a href="{{ path('app_etablissements_edit', {'id': etablissement.id}) }}" class="btn btn-warning btn-sm">✏ Modifier</a>
        </div>
    </div>

    <div class="row g-4">
        {# Image #}
        {% if etablissement.imageUrl %}
        <div class="col-md-4">
            <div class="card border-0 shadow-sm">
                <img src="{{ etablissement.imageUrl }}" alt="{{ etablissement.nom }}" class="card-img-top" style="height: 250px; object-fit: cover;">
            </div>
        </div>
        <div class="col-md-8">
        {% else %}
        <div class="col-md-12">
        {% endif %}
            <div class="card shadow-sm border-0">
                <div class="card-body">
                    <table class="table table-bordered align-middle">
                        <tbody>
                            <tr><th class="bg-light w-25">Nom</th><td class="fw-semibold text-primary">{{ etablissement.nom }}</td></tr>
                            <tr><th class="bg-light">Adresse</th><td>{{ etablissement.adresse }}</td></tr>
                            <tr><th class="bg-light">Ville</th><td>{{ etablissement.ville }}</td></tr>
                            <tr><th class="bg-light">Téléphone</th><td>{{ etablissement.telephone }}</td></tr>
                            <tr><th class="bg-light">Email</th><td>{{ etablissement.email }}</td></tr>
                        </tbody>
                    </table>

                    <div class="d-flex gap-2 justify-content-end mt-3">
                        <a href="{{ path('app_etablissements_edit', {'id': etablissement.id}) }}" class="btn btn-warning">✏ Modifier</a>
                        {{ include('eta/_delete_form.html.twig') }}
                    </div>
                </div>
            </div>
        </div>
    </div>

</div>

{% endblock %}
