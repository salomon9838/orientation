{% extends 'base.html.twig' %}

{% block title %}Etablissement{% endblock %}

{% block body %}

<div class="container mt-5">

    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-bold text-primary">🏫 Détails de l’établissement</h2>

        <div>
            <a href="{{ path('app_etablissements_index') }}" class="btn btn-secondary btn-sm">
                ⬅ Retour
            </a>

            <a href="{{ path('app_etablissements_edit', {'id': etablissement.id}) }}" class="btn btn-warning btn-sm">
                ✏ Modifier
            </a>
        </div>
    </div>

    <div class="card shadow-lg border-0">
        <div class="card-body">

            <table class="table table-bordered align-middle">
                <tbody>
                    <tr>
                        <th class="bg-light w-25">Id</th>
                        <td>{{ etablissement.id }}</td>
                    </tr>
                    <tr>
                        <th class="bg-light">Nom</th>
                        <td class="fw-semibold text-primary">{{ etablissement.nom }}</td>
                    </tr>
                    <tr>
                        <th class="bg-light">Adresse</th>
                        <td>{{ etablissement.adresse }}</td>
                    </tr>
                    <tr>
                        <th class="bg-light">Ville</th>
                        <td>{{ etablissement.ville }}</td>
                    </tr>
                    <tr>
                        <th class="bg-light">Téléphone</th>
                        <td>{{ etablissement.telephone }}</td>
                    </tr>
                    <tr>
                        <th class="bg-light">Email</th>
                        <td>{{ etablissement.email }}</td>
                    </tr>
                </tbody>
            </table>

            <div class="mt-4 d-flex justify-content-between">
                <div>
                    <a href="{{ path('app_etablissements_index') }}" class="btn btn-outline-secondary">
                        ⬅ Retour à la liste
                    </a>
                </div>

                <div class="d-flex gap-2">
                    <a href="{{ path('app_etablissements_edit', {'id': etablissement.id}) }}" class="btn btn-warning">
                        ✏ Modifier
                    </a>

                    <div>
                        {{ include('eta/_delete_form.html.twig') }}
                    </div>
                </div>
            </div>

        </div>
    </div>

</div>

{% endblock %}