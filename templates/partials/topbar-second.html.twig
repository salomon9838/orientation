{# Bouton Voir Tout #}
<div class="px-5 py-3 text-center bg-white position-absolute bottom-0 border-top border-dashed w-100 text-center">
    <a href="#!" class="text-inherit">Voir toutes les notifications</a>
</div>

{# Modal de recherche #}
<div class="modal fade" id="searchModal" tabindex="-1" aria-labelledby="searchModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header border-0">
                <input type="search" class="form-control border-0 rounded-0 ps-0 form-focus-none" id="globalSearchInput"
                       placeholder="Rechercher un élève, un prof ou une classe..." aria-label="Recherche" aria-describedby="search-addon" />
                <button type="button" class="btn btn-white btn-sm" data-bs-dismiss="modal" aria-label="Fermer">Esc</button>
            </div>
        </div>
    </div>
</div>