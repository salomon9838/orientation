{% extends 'base.html.twig' %}

{% block title %}Utilisateurs - SchoolPrepar{% endblock %}

{% block body %}
<div class="container py-5">

    <div class="card shadow border-0 rounded-3">
        <div class="card-body p-4">

            <h2 class="text-center fw-bold text-primary mb-4">
                Liste des utilisateurs
            </h2>

            {% if utilisateurs|length > 0 %}
                <div class="row g-4">
                    {% for utilisateur in utilisateurs %}
                        <div class="col-12 col-sm-6 col-lg-3">
                            <div class="card h-100 shadow-sm border-0 text-center transition-hover">
                                {% if utilisateur.imageUrl %}
                                    <img src="{{ utilisateur.imageUrl }}" alt="{{ utilisateur.prenom }} {{ utilisateur.nom }}" class="card-img-top img-fluid" style="height: 200px; object-fit: cover;">
                                {% else %}
                                    <div class="card-img-top bg-light d-flex align-items-center justify-content-center" style="height: 200px;">
                                        <i class="fa fa-user fa-3x text-muted"></i>
                                    </div>
                                {% endif %}
                                <div class="card-body">
                                    <h5 class="card-title fw-bold">{{ utilisateur.prenom }} {{ utilisateur.nom }}</h5>
                                    <p class="card-text text-muted small">{{ utilisateur.email }}</p>
                                    {% for role in utilisateur.roles %}
                                        {% if role != 'ROLE_USER' or utilisateur.roles|length == 1 %}
                                            <span class="badge bg-{{ role == 'ROLE_ADMIN' ? 'danger' : 'info text-dark' }} d-inline-block mb-2">
                                                {{ role == 'ROLE_ADMIN' ? 'Admin' : 'Utilisateur' }}
                                            </span>
                                        {% endif %}
                                    {% endfor %}
                                </div>
                                <div class="card-footer bg-white border-0 p-2">
                                    <a href="{{ path('app_utilisateur_show', {'id': utilisateur.id}) }}" class="btn btn-sm btn-outline-primary me-1">
                                        <i class="fa fa-eye"></i> Voir
                                    </a>
                                    <a href="{{ path('app_utilisateur_edit', {'id': utilisateur.id}) }}" class="btn btn-sm btn-outline-warning">
                                        <i class="fa fa-edit"></i> Modifier
                                    </a>
                                </div>
                            </div>
                        </div>
                    {% endfor %}
                </div>
            {% else %}
                <div class="text-center text-muted py-5">
                    <p>Aucun utilisateur trouvé</p>
                </div>
            {% endif %}

            <div class="d-flex justify-content-end mt-4">
                <a href="{{ path('app_utilisateur_new') }}" class="btn btn-success">
                    <i class="fa fa-plus"></i> Créer un utilisateur
                </a>
            </div>

        </div>
    </div>

</div>
{% endblock %}
