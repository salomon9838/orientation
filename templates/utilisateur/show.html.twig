{% extends 'base.html.twig' %}

{% block title %}Utilisateur{% endblock %}

{% block stylesheets %}
    {{ parent() }}

    <!-- Bootstrap 5 -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
{% endblock %}

{% block body %}
<div class="container py-5">

    <div class="row justify-content-center">
        <div class="col-lg-8">

            <div class="card shadow border-0 rounded-3">
                <div class="card-body p-5">

                    <h2 class="text-center fw-bold text-primary mb-4">
                        Détails de l'utilisateur
                    </h2>

                    <div class="table-responsive">
                        <table class="table table-bordered align-middle">
                            <tbody>
                                <tr>
                                    <th class="table-light w-25">Id</th>
                                    <td>{{ utilisateur.id }}</td>
                                </tr>
                                <tr>
                                    <th class="table-light">Nom</th>
                                    <td class="fw-semibold">{{ utilisateur.nom }}</td>
                                </tr>
                                <tr>
                                    <th class="table-light">Prénom</th>
                                    <td>{{ utilisateur.prenom }}</td>
                                </tr>
                                <tr>
                                    <th class="table-light">Email</th>
                                    <td>{{ utilisateur.email }}</td>
                                </tr>
                                <tr>
                                    <th class="table-light">Mot de passe</th>
                                    <td>
                                        <span class="text-muted">••••••••</span>
                                    </td>
                                </tr>
                                <tr>
                                    <th class="table-light">Rôle</th>
                                    <td>
                                        <span class="badge bg-info text-dark">
                                            {{ utilisateur.role }}
                                        </span>
                                    </td>
                                </tr>
                            </tbody>
                        </table>
                    </div>

                    <div class="d-flex justify-content-between mt-4">

                        <a href="{{ path('app_utilisateur_index') }}" class="btn btn-outline-secondary">
                            ← Retour
                        </a>

                        <div class="d-flex gap-2">
                            <a href="{{ path('app_utilisateur_edit', {'id': utilisateur.id}) }}" class="btn btn-warning">
                                Modifier
                            </a>

                            {{ include('utilisateur/_delete_form.html.twig') }}
                        </div>

                    </div>

                </div>
            </div>

        </div>
    </div>

</div>
{% endblock %}