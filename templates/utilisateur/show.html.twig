{% extends 'base.html.twig' %}

{% block title %}{{ utilisateur.prenom }} {{ utilisateur.nom }} - Utilisateur{% endblock %}

{% block body %}
<div class="container py-4">

    <div class="row justify-content-center">
        <div class="col-lg-8">
            <div class="card shadow border-0 rounded-3">
                <div class="card-body p-4">

                    <h2 class="text-center fw-bold text-primary mb-4">
                        Détails de l'utilisateur
                    </h2>

                    {# Photo de profil #}
                    <div class="text-center mb-4">
                        <img src="{{ utilisateur.imageUrl ?: asset('assets/img/team/2.jpg') }}" alt="{{ utilisateur.prenom }} {{ utilisateur.nom }}"
                            class="rounded-circle img-thumbnail"
                            style="width: 120px; height: 120px; object-fit: cover;">
                    </div>

                    <table class="table table-bordered align-middle">
                        <tbody>
                            <tr><th class="table-light w-25">Nom</th><td class="fw-semibold">{{ utilisateur.nom }}</td></tr>
                            <tr><th class="table-light">Prénom</th><td>{{ utilisateur.prenom }}</td></tr>
                            <tr><th class="table-light">Email</th><td>{{ utilisateur.email }}</td></tr>
                            <tr>
                                <th class="table-light">Rôle(s)</th>
                                <td>
                                    {% for role in utilisateur.roles %}
                                        <span class="badge bg-{{ role == 'ROLE_ADMIN' ? 'danger' : 'info text-dark' }} me-1">
                                            {{ role == 'ROLE_ADMIN' ? 'Administrateur' : 'Utilisateur' }}
                                        </span>
                                    {% endfor %}
                                </td>
                            </tr>
                            {% if utilisateur.filiere %}
                            <tr><th class="table-light">Filière</th><td>{{ utilisateur.filiere.nom }}</td></tr>
                            {% endif %}
                        </tbody>
                    </table>

                    <div class="d-flex justify-content-between mt-4">
                        <a href="{{ path('app_utilisateur_index') }}" class="btn btn-outline-secondary">← Retour</a>
                        <div class="d-flex gap-2">
                            <a href="{{ path('app_utilisateur_edit', {'id': utilisateur.id}) }}" class="btn btn-warning">✏ Modifier</a>
                            {{ include('utilisateur/_delete_form.html.twig') }}
                        </div>
                    </div>

                </div>
            </div>
        </div>
    </div>

</div>
{% endblock %}
