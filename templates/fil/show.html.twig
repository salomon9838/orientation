{% extends 'base.html.twig' %}

{% block title %}{{ filiere.nom }} - Filière{% endblock %}

{% block body %}
<div class="container py-4">

    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-bold text-primary">{{ filiere.nom }}</h2>
        <div>
            <a href="{{ path('app_filieres_index') }}" class="btn btn-secondary btn-sm">← Retour</a>
            <a href="{{ path('app_filieres_edit', {'id': filiere.id}) }}" class="btn btn-warning btn-sm">✏ Modifier</a>
        </div>
    </div>

    <div class="row g-4">
        {% if filiere.imageUrl %}
        <div class="col-md-4">
            <div class="card border-0 shadow-sm">
                <img src="{{ filiere.imageUrl }}" alt="{{ filiere.nom }}" class="card-img-top" style="height: 220px; object-fit: cover;">
            </div>
        </div>
        <div class="col-md-8">
        {% else %}
        <div class="col-md-12">
        {% endif %}
            <div class="card shadow-sm border-0">
                <div class="card-body">
                    <table class="table table-bordered align-middle">
                        <tbody>
                            <tr><th class="table-light w-25">Nom</th><td class="fw-semibold">{{ filiere.nom }}</td></tr>
                            <tr><th class="table-light">Description</th><td>{{ filiere.description }}</td></tr>
                            <tr><th class="table-light">Établissement</th><td>{{ filiere.etablissement ? filiere.etablissement.nom : 'N/A' }}</td></tr>
                            <tr><th class="table-light">Créé le</th><td>{{ filiere.createdAt ? filiere.createdAt|date('d/m/Y') : 'N/A' }}</td></tr>
                        </tbody>
                    </table>

                    <div class="d-flex gap-2 justify-content-end mt-3">
                        <a href="{{ path('app_filieres_edit', {'id': filiere.id}) }}" class="btn btn-warning">✏ Modifier</a>
                        {{ include('fil/_delete_form.html.twig') }}
                    </div>
                </div>
            </div>
        </div>
    </div>

</div>
{% endblock %}
