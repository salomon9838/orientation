{% extends 'base.html.twig' %}

{% block title %}Filiere{% endblock %}

{% block stylesheets %}
    {{ parent() }}

    <!-- Bootstrap 5 -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
{% endblock %}

{% block body %}
<div class="container py-5">

    <div class="card shadow-sm border-0">
        <div class="card-body">

            <h1 class="text-center fw-bold mb-4">Filiere</h1>

            <div class="table-responsive">
                <table class="table table-bordered table-hover align-middle">
                    <tbody>
                        <tr>
                            <th class="table-light w-25">Id</th>
                            <td>{{ filiere.id }}</td>
                        </tr>
                        <tr>
                            <th class="table-light">Nom</th>
                            <td class="fw-semibold">{{ filiere.nom }}</td>
                        </tr>
                        <tr>
                            <th class="table-light">Description</th>
                            <td>{{ filiere.description }}</td>
                        </tr>
                        <tr>
                            <th class="table-light">CreatedAt</th>
                            <td>{{ filiere.createdAt|date('d/m/Y') }}</td>
                        </tr>
                    </tbody>
                </table>
            </div>

            <div class="d-flex justify-content-between mt-4">
                <a href="{{ path('app_filieres_index') }}" class="btn btn-outline-secondary">
                    ← Retour
                </a>

                <div>
                    <a href="{{ path('app_filieres_edit', {'id': filiere.id}) }}" class="btn btn-warning me-2">
                        Modifier
                    </a>

                    {{ include('fil/_delete_form.html.twig') }}
                </div>
            </div>

        </div>
    </div>

</div>
{% endblock %}