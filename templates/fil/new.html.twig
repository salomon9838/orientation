{% extends 'base.html.twig' %}

{% block title %}New Filiere{% endblock %}

{% block stylesheets %}
    {{ parent() }}

    <!-- Bootstrap 5 -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
{% endblock %}

{% block body %}
<div class="container py-5">

    <div class="card shadow-sm border-0">
        <div class="card-body">

            <h1 class="text-center fw-bold mb-4">Créer une nouvelle Filière</h1>

            <div class="mb-4">
                {{ include('fil/_form.html.twig') }}
            </div>

            <div class="text-start">
                <a href="{{ path('app_filieres_index') }}" class="btn btn-outline-secondary">
                    ← Retour à la liste
                </a>
            </div>

        </div>
    </div>

</div>
{% endblock %}